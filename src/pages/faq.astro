---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "FAQ — Häufige Fragen zur Marketing-Agentur | Oberbeck Marketing";
const description = "Antworten auf alle Fragen zu Marketing, Webdesign, Google Ads, SEO und Preisen. Für KMU in Laumersheim, Ludwigshafen, Mannheim und Umgebung.";

const faqs = [
  {
    question: "Was kostet eine Marketing-Agentur?",
    answer: "Die Kosten hängen vom Projektumfang ab. Einzelne Leistungen wie Google Ads starten ab 500€/Monat, eine komplette Website ab 2.500€ einmalig. Wir erstellen immer individuelle Angebote, die zu Ihrem Budget passen. In einem kostenlosen Erstgespräch besprechen wir Ihre Ziele und ich zeige Ihnen, wo sich Marketing für Sie lohnt.",
    category: "Preise"
  },
  {
    question: "Wie lange dauert es, bis meine Website fertig ist?",
    answer: "Eine professionelle Business-Website ist in der Regel innerhalb von 4-6 Wochen fertig. Das hängt natürlich vom Umfang ab — eine einfache Landing Page kann in 2 Wochen gehen, ein komplexer Shop mit 100+ Produkten braucht 2-3 Monate. Wir legen vor Projektstart einen festen Zeitplan fest, den wir auch einhalten.",
    category: "Webdesign"
  },
  {
    question: "Was ist der Unterschied zwischen SEO und Google Ads?",
    answer: "Google Ads sind bezahlte Anzeigen, die sofort oben in den Suchergebnissen erscheinen — Sie zahlen pro Klick. SEO (Suchmaschinenoptimierung) ist langfristiges Arbeiten an Ihrer Website, damit sie organisch (kostenlos) gut rankt. Beides hat seine Berechtigung: Ads für schnelle Ergebnisse, SEO für nachhaltigen Erfolg. Die meisten Kunden nutzen beides kombiniert.",
    category: "SEO & Ads"
  },
  {
    question: "Braucht mein Unternehmen Social Media?",
    answer: "Das kommt auf Ihre Zielgruppe an. B2C-Unternehmen (Einzelhandel, Gastronomie, Handwerk) profitieren meist stark von Instagram und Facebook. B2B-Unternehmen sollten sich auf LinkedIn konzentrieren. Wir analysieren Ihre Zielgruppe und empfehlen Ihnen, welche Kanäle sich wirklich lohnen — ohne das Streuen auf Kanälen, die für Sie nicht relevant sind.",
    category: "Social Media"
  },
  {
    question: "Wie messe ich den Erfolg meines Marketings?",
    answer: "Wir legen zu Projektbeginn klare KPIs (Key Performance Indicators) fest: Website-Besucher, Anfragen über Kontaktformular, Telefonanrufe, Verkäufe, Newsletter-Anmeldungen. Über ein Dashboard sehen Sie jederzeit, wie Ihre Kampagnen laufen. Monatlich bekommen Sie einen ausführlichen Report mit Ergebnissen und Optimierungsvorschlägen.",
    category: "Analytics"
  },
  {
    question: "Arbeiten Sie auch mit Unternehmen außerhalb von Laumersheim?",
    answer: "Ja, absolut! Während unser Büro in Laumersheim ist, betreuen wir Kunden in ganz Rheinland-Pfalz — von Ludwigshafen und Mannheim über Grünstadt, Frankenthal, Bad Dürkheim bis nach Worms. Dank Video-Calls und moderner Projektmanagement-Tools funktioniert die Zusammenarbeit genauso gut wie vor Ort.",
    category: "Region"
  },
  {
    question: "Kann ich bestehende Marketing-Maßnahmen weiterlaufen lassen?",
    answer: "Natürlich. Wir passen uns Ihrem Setup an. Ob Sie schon mit einer anderen Agentur arbeiten und nur Unterstützung bei Google Ads brauchen, oder ob Sie von Grund auf neu starten wollen — wir sind flexibel. Viele Kunden behalten interne Ressourcen bei und wir ergänzen gezielt dort, wo Expertise fehlt.",
    category: "Zusammenarbeit"
  },
  {
    question: "Wie schnell sehe ich Ergebnisse bei Google Ads?",
    answer: "Google Ads zeigen sofort Ergebnisse — schon innerhalb von 24-48 Stunden nach Kampagnen-Start. Aber: Die ersten Tage sind Lernphase. Wir optimieren Keywords, Anzeigentexte und Budget-Verteilung. Nach 2-4 Wochen läuft die Kampagne dann richtig rund mit der besten Cost-per-Conversion.",
    category: "Google Ads"
  },
  {
    question: "Wie lange dauert SEO, bis ich auf Seite 1 bei Google bin?",
    answer: "Realistisch sind 3-6 Monate für sichtbare Verbesserungen, 6-12 Monate für Top-10-Rankings bei mittlerem Wettbewerb. SEO ist ein Marathon, kein Sprint — aber die Ergebnisse halten auch Jahre an, ohne dass Sie weiter dafür zahlen müssen. Wir zeigen Ihnen monatlich, wie sich Ihre Rankings entwickeln.",
    category: "SEO"
  },
  {
    question: "Was passiert nach Projektabschluss?",
    answer: "Wir bieten verschiedene Betreuungsmodelle an: Von 'Hands-off' (Sie führen selbst weiter) bis hin zu monatlichen Wartungs- und Optimierungsverträgen. Viele Kunden bleiben langfristig bei uns, weil kontinuierliches Marketing bessere Ergebnisse bringt als Einzelaktionen.",
    category: "Service"
  }
];

// Group FAQs by category
const categories = [...new Set(faqs.map(faq => faq.category))];
---

<Layout title={title} description={description}>
  <Navigation />
  
  <div class="min-h-screen bg-gradient-to-b from-[#faf8f5] to-white">
    
    {/* Hero Section */}
    <section class="pt-32 pb-16 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[#52baeb]/5 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
          <a href="/" class="hover:text-[#1e3a5f] transition-colors">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-[#1e3a5f] font-medium">FAQ</span>
        </nav>
        
        <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Fragen & Antworten</span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1a1a1a] mb-6 leading-tight">
          Marketing-Verständlich erklärt
        </h1>
        <p class="text-xl text-[#64748b] max-w-2xl">
          Antworten auf die häufigsten Fragen zu unseren Leistungen, Abläufen und Preisen. 
          Für Unternehmen in <strong>Laumersheim, Ludwigshafen, Mannheim</strong> und Umgebung.
        </p>
      </div>
    </section>

    {/* FAQ Categories */}
    <section class="pb-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {categories.map((category) => (
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-[#1a1a1a] mb-6 flex items-center gap-3">
              <span class="w-8 h-8 bg-[#52baeb]/10 rounded-lg flex items-center justify-center text-[#52baeb] text-sm">
                {category.charAt(0)}
              </span>
              {category}
            </h2>
            
            <div class="space-y-4">
              {faqs.filter(faq => faq.category === category).map((faq, index) => (
                <details class="group bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                  <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-slate-50 transition-colors">
                    <h3 class="text-lg font-semibold text-[#1a1a1a] pr-4">{faq.question}</h3>
                    <span class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center flex-shrink-0 group-open:bg-[#52baeb] group-open:text-white transition-colors">
                      <svg class="w-5 h-5 transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-6 text-[#64748b] leading-relaxed">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}

        {/* CTA */}
        <div class="mt-16 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a] rounded-3xl p-8 lg:p-12 text-center">
          <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
            Noch Fragen offen?
          </h2>
          <p class="text-slate-300 mb-8 max-w-xl mx-auto">
            In einem kostenlosen Erstgespräch klären wir alle offenen Punkte. 
            Ohne Verpflichtung, ohne Verkaufsdruck.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="/#kontakt" 
              class="inline-flex items-center justify-center px-8 py-4 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-colors"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Kostenloses Erstgespräch
            </a>
            <a 
              href="tel:+4915228875801" 
              class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              +49 152 28875801
            </a>
          </div>
        </div>

        {/* Schema Markup */}
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": faqs.map(faq => ({
            "@type": "Question",
            "name": faq.question,
            "acceptedAnswer": {
              "@type": "Answer",
              "text": faq.answer
            }
          }))
        })} />
      </div>
    </section>
  </div>
  
  <Footer />
</Layout>
