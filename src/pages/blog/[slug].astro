---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: any) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get related posts (same tags, exclude current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p: any) => p.id !== post.id && p.data.tags.some((tag: string) => post.data.tags.includes(tag)))
  .slice(0, 2);
---

<Layout 
  title={`${post.data.title} — Oberbeck Marketing`} 
  description={post.data.description}
  image={post.data.image}
  canonical={`/blog/${post.id}`}
  article={true}
  pubDate={post.data.pubDate}
  author={post.data.author}
  tags={post.data.tags}
>
  <Navigation />
  
  <article class="min-h-screen">
    
    {/* Hero Section with Image */}
    <header class="relative">
      <!-- Background Image -->
      <div class="absolute inset-0">
        <img 
          src={post.data.image || '/images/blog-placeholder.jpg'} 
          alt=""
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a] via-[#1a1a1a]/80 to-[#1a1a1a]/40"></div>
      </div>
      
      <div class="relative pt-32 pb-20 lg:pt-40 lg:pb-28">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          
          {/* Breadcrumb */}
          <nav class="flex items-center gap-2 text-sm text-white/70 mb-8">
            <a href="/" class="hover:text-white transition-colors">Startseite</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <a href="/blog" class="hover:text-white transition-colors">Blog</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-white">Artikel</span>
          </nav>
          
          {/* Tags */}
          <div class="flex flex-wrap gap-2 mb-6">
            {post.data.tags.map((tag: string) => (
              <span class="inline-flex items-center gap-1.5 text-sm text-white/90 bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                </svg>
                {tag}
              </span>
            ))}
          </div>
          
          {/* Title */}
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-8 leading-tight">
            {post.data.title}
          </h1>
          
          {/* Meta */}
          <div class="flex flex-wrap items-center gap-6 text-white/80">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#52baeb] to-[#3a9bd1] flex items-center justify-center text-white font-bold text-sm">
                PO
              </div>
              <div>
                <p class="text-white font-medium">{post.data.author}</p>
                <p class="text-sm text-white/60">Marketing-Experte</p>
              </div>
            </div>
            
            <div class="h-8 w-px bg-white/20 hidden sm:block"></div>
            
            <time class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {post.data.pubDate.toLocaleDateString('de-DE', { 
                weekday: 'long', 
                day: 'numeric', 
                month: 'long', 
                year: 'numeric' 
              })}
            </time>
            
            <div class="h-8 w-px bg-white/20 hidden sm:block"></div>
            
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {post.data.readingTime || '5'} Min. Lesezeit
            </span>
          </div>
        </div>
      </div>
    </header>

    {/* Content */}
    <div class="py-12 lg:py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="blog-content">
          <Content />
        </div>
        
        {/* Share */}
        <div class="mt-12 pt-8 border-t border-slate-100">
          <p class="text-sm text-slate-500 mb-4">Artikel teilen:</p>
          <div class="flex gap-3">
            <a 
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 flex items-center justify-center text-slate-600 transition-colors"
              aria-label="Auf X teilen"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            
            <a 
              href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + Astro.url)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 flex items-center justify-center text-slate-600 transition-colors"
              aria-label="Auf WhatsApp teilen"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.28 1.26h.006c6.555 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.484-8.413z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Related Posts */}
    {relatedPosts.length > 0 && (
      <section class="py-16 bg-[#faf8f5]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-12">
            <span class="text-sm font-semibold text-[#52baeb] uppercase tracking-wider">Weiterlesen</span>
            <h2 class="text-3xl font-bold text-[#1a1a1a] mt-2">Ähnliche Artikel</h2>
          </div>
          
          <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            {relatedPosts.map((relatedPost: any) => (
              <a href={`/blog/${relatedPost.slug}`} class="group">
                <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
                  <div class="aspect-video overflow-hidden">
                    <img 
                      src={relatedPost.data.image || '/images/blog-placeholder.jpg'} 
                      alt={relatedPost.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                  
                  <div class="p-6">
                    <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
                      <time>{relatedPost.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long' })}</time>
                      <span>·</span>
                      <span>{relatedPost.data.readingTime || '5'} Min.</span>
                    </div>
                    
                    <h3 class="text-xl font-bold text-[#1a1a1a] group-hover:text-[#1e3a5f] transition-colors">
                      {relatedPost.data.title}
                    </h3>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* CTA */}
    <section class="py-16 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="w-16 h-16 mx-auto mb-6 bg-white/10 rounded-2xl flex items-center justify-center">
          <svg class="w-8 h-8 text-[#52baeb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        
        <h2 class="text-3xl font-bold text-white mb-4">
          Fragen zum Artikel?
        </h2>
        
        <p class="text-lg text-slate-300 mb-8 max-w-xl mx-auto">
          Wir helfen Ihnen gerne bei der Umsetzung. Vereinbaren Sie ein kostenloses Erstgespräch.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a 
            href="/#kontakt" 
            class="inline-flex items-center px-8 py-4 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-colors"
          >
            Termin vereinbaren
          </a>
          
          <a 
            href="/blog" 
            class="inline-flex items-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors"
          >
            Alle Artikel
          </a>
        </div>
      </div>
    </section>
  </article>
  
  <Footer />
</Layout>

<style>
  .blog-content {
    color: #334155;
    line-height: 1.8;
    font-size: 1.125rem;
  }
  
  .blog-content :global(h2) {
    font-size: 1.875rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    line-height: 1.3;
  }
  
  .blog-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  
  .blog-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .blog-content :global(p) {
    margin-bottom: 1.75rem;
  }
  
  .blog-content :global(p:first-of-type) {
    font-size: 1.25rem;
    color: #475569;
    font-weight: 400;
  }
  
  .blog-content :global(ul), .blog-content :global(ol) {
    margin-bottom: 1.75rem;
    padding-left: 1.5rem;
  }
  
  .blog-content :global(ul) {
    list-style-type: none;
  }
  
  .blog-content :global(ul li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .blog-content :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 6px;
    height: 6px;
    background: #52baeb;
    border-radius: 50%;
  }
  
  .blog-content :global(ol) {
    list-style-type: decimal;
  }
  
  .blog-content :global(ol li) {
    padding-left: 0.5rem;
    margin-bottom: 0.75rem;
  }
  
  .blog-content :global(a) {
    color: #1e3a5f;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 2px solid #52baeb;
    transition: all 0.2s;
  }
  
  .blog-content :global(a:hover) {
    color: #52baeb;
    border-bottom-color: #1e3a5f;
  }
  
  .blog-content :global(strong) {
    color: #1a1a1a;
    font-weight: 600;
  }
  
  .blog-content :global(blockquote) {
    border-left: 4px solid #52baeb;
    background: #f8fafc;
    padding: 1.5rem 2rem;
    margin: 2.5rem 0;
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: italic;
    color: #1e3a5f;
  }
  
  .blog-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  
  .blog-content :global(code) {
    background: #f1f5f9;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    color: #1e3a5f;
  }
  
  .blog-content :global(pre) {
    background: #1e3a5f;
    color: white;
    padding: 1.5rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-bottom: 1.75rem;
  }
  
  .blog-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  
  .blog-content :global(img) {
    border-radius: 0.75rem;
    margin: 2rem 0;
    width: 100%;
  }
  
  .blog-content :global(hr) {
    border: none;
    border-top: 2px solid #e2e8f0;
    margin: 3rem 0;
  }
</style>