---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: any) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Oberbeck Marketing`} description={post.data.description}>
  <article class="pt-24 pb-16 bg-[#faf8f5] min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Back Link -->
      <a href="/blog" class="inline-flex items-center text-slate-500 hover:text-[#1e3a5f] transition-colors mb-8">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Alle Artikel
      </a>

      <!-- Header -->
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          {post.data.tags.map((tag: string) => (
            <span class="text-sm text-[#1e3a5f] bg-[#1e3a5f]/10 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          {post.data.title}
        </h1>

        <div class="flex items-center gap-6 text-slate-500">
          <time class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {post.data.pubDate.toLocaleDateString('de-DE', { 
              weekday: 'long', 
              day: 'numeric', 
              month: 'long', 
              year: 'numeric' 
            })}
          </time>

          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            {post.data.author}
          </span>
        </div>
      </header>

      <!-- Featured Image -->
      {post.data.image && (
        <div class="mb-12 rounded-2xl overflow-hidden">
          <img 
            src={post.data.image} 
            alt={post.data.title}
            class="w-full aspect-video object-cover"
          />
        </div>
      )}

      <!-- Content -->
      <div class="blog-content">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 bg-[#1e3a5f] rounded-2xl text-center">
        <h3 class="text-xl font-bold text-white mb-2">Hilfreich? Lassen Sie uns reden.</h3>
        <p class="text-slate-300 mb-6">Ich helfe Ihnen gerne bei der Umsetzung.</p>
        <a 
          href="/" 
          class="inline-flex items-center px-6 py-3 bg-[#52baeb] hover:bg-amber-600 text-white font-semibold rounded-xl transition-colors"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .blog-content {
    color: #64748b;
    line-height: 1.75;
  }
  
  .blog-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  
  .blog-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .blog-content :global(p) {
    margin-bottom: 1.5rem;
  }
  
  .blog-content :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .blog-content :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .blog-content :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .blog-content :global(a) {
    color: #1e3a5f;
    text-decoration: underline;
  }
  
  .blog-content :global(a:hover) {
    color: #52baeb;
  }
  
  .blog-content :global(strong) {
    color: #1a1a1a;
    font-weight: 600;
  }
  
  .blog-content :global(blockquote) {
    border-left: 4px solid #52baeb;
    padding-left: 1.5rem;
    font-style: italic;
    color: #1a1a1a;
    margin: 2rem 0;
  }
</style>