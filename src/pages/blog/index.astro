---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group posts by year
const postsByYear = sortedPosts.reduce((acc: any, post: any) => {
  const year = post.data.pubDate.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title="Blog — Oberbeck Marketing" description="Praktische Marketing-Tipps für KMU in Rheinland-Pfalz">
  <Navigation />
  
  <div class="min-h-screen bg-gradient-to-b from-[#faf8f5] to-white">
    
    {/* Hero Section */}
    <section class="pt-32 pb-16 relative overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[#52baeb]/5 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
          <a href="/" class="hover:text-[#1e3a5f] transition-colors">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-[#1e3a5f] font-medium">Blog</span>
        </nav>
        
        <div class="max-w-3xl">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Blog</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1a1a1a] mb-6 leading-tight">
            Marketing-Wissen für <span class="text-[#1e3a5f]">KMU</span>
          </h1>
          <p class="text-xl text-[#64748b] max-w-2xl">
            Praktische Tipps, aktuelle Trends und erprobte Strategien — 
            alles, was Sie für erfolgreiches Marketing brauchen.
          </p>
        </div>
      </div>
    </section>

    {/* Posts Grid */}
    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {sortedPosts.length > 0 ? (
          <div class="grid lg:grid-cols-3 gap-8">
            
            {/* Featured Post (first/latest) */}
            <div class="lg:col-span-2 lg:row-span-2">
              <a href={`/blog/${sortedPosts[0].id}`} class="group block h-full">
                <article class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 h-full flex flex-col">
                  <div class="relative aspect-[16/10] overflow-hidden">
                    <img 
                      src={sortedPosts[0].data.image || '/images/blog-placeholder.jpg'} 
                      alt={sortedPosts[0].data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    />
                    <div class="absolute top-4 left-4">
                      <span class="inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-[#1e3a5f] text-xs font-semibold px-3 py-1.5 rounded-full">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                        Neuster Beitrag
                      </span>
                    </div>
                  </div>
                  
                  <div class="p-8 flex-1 flex flex-col">
                    <div class="flex flex-wrap items-center gap-3 mb-4">
                      <time class="text-sm text-slate-500 flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        {sortedPosts[0].data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </time>
                      
                      <span class="text-slate-300">·</span>
                      
                      <span class="text-sm text-slate-500">{sortedPosts[0].data.readingTime || '5'} Min. Lesezeit</span>
                    </div>                    
                    
                    <h2 class="text-2xl sm:text-3xl font-bold text-[#1a1a1a] mb-4 group-hover:text-[#1e3a5f] transition-colors line-clamp-2">
                      {sortedPosts[0].data.title}
                    </h2>                    
                    
                    <p class="text-[#64748b] mb-6 line-clamp-3 flex-1">{sortedPosts[0].data.description}</p>
                    
                    <div class="flex items-center justify-between">
                      <div class="flex flex-wrap gap-2">
                        {sortedPosts[0].data.tags.slice(0, 3).map((tag: string) => (
                          <span class="text-xs text-[#1e3a5f] bg-[#1e3a5f]/5 px-2.5 py-1 rounded-full font-medium">{tag}</span>
                        ))}
                      </div>
                      
                      <span class="flex items-center gap-1 text-[#1e3a5f] font-semibold text-sm group-hover:gap-2 transition-all">
                        Lesen
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                      </span>
                    </div>
                  </div>
                </article>
              </a>
            </div>

            {/* Regular Posts */}
            <div class="contents">
              {sortedPosts.slice(1).map((post: any) => (
                <a href={`/blog/${post.id}`} class="group block">
                  <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 h-full flex flex-col">
                    <div class="relative aspect-[16/9] overflow-hidden">
                      <img 
                        src={post.data.image || '/images/blog-placeholder.jpg'} 
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      />
                    </div>
                    
                    <div class="p-6 flex-1 flex flex-col">
                      <div class="flex flex-wrap items-center gap-2 mb-3 text-xs text-slate-500">
                        <time>{post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'short' })}</time>
                        <span>·</span>
                        <span>{post.data.readingTime || '5'} Min.</span>
                      </div>
                      
                      <h3 class="text-lg font-bold text-[#1a1a1a] mb-3 group-hover:text-[#1e3a5f] transition-colors line-clamp-2">
                        {post.data.title}
                      </h3>
                      
                      <p class="text-sm text-[#64748b] mb-4 line-clamp-2 flex-1">{post.data.description}</p>
                      
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="text-xs text-[#1e3a5f] bg-[#1e3a5f]/5 px-2 py-0.5 rounded-full">{tag}</span>
                        ))}
                      </div>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="text-center py-20">
            <div class="w-20 h-20 mx-auto mb-6 bg-slate-100 rounded-full flex items-center justify-center">
              <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-[#1a1a1a] mb-2">Noch keine Beiträge</h3>
            <p class="text-[#64748b]">Hier werden bald spannende Artikel erscheinen.</p>
          </div>
        )}
      </div>
    </section>

    {/* CTA Section */}
    <section class="py-16 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
          Hilfe beim Umsetzen?
        </h2>
        <p class="text-lg text-slate-300 mb-8 max-w-xl mx-auto">
          Wir unterstützen Sie bei der Umsetzung der Strategien aus unseren Artikeln.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a 
            href="/#kontakt" 
            class="inline-flex items-center px-8 py-4 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            Kostenloses Erstgespräch
          </a>
          
          <a 
            href="/" 
            class="inline-flex items-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors"
          >
            Zurück zur Startseite
          </a>
        </div>
      </div>
    </section>
  </div>
  
  <Footer />
</Layout>