---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — Oberbeck Marketing" description="Praktische Marketing-Tipps für KMU in Rheinland-Pfalz">
  <div class="pt-24 pb-16 bg-[#faf8f5] min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header -->
      <div class="mb-12">
        <a href="/" class="inline-flex items-center text-[#64748b] hover:text-[#1e3a5f] transition-colors mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Zurück zur Startseite
        </a>
        
        <h1 class="text-4xl sm:text-5xl font-bold text-[#1a1a1a] mb-4">Blog</h1>
        <p class="text-xl text-[#64748b]">
          Praktisches Marketing-Wissen für KMU — aus erster Hand.
        </p>
      </div>

      <!-- Posts Grid -->
      {sortedPosts.length > 0 ? (
        <div class="space-y-8">
          {sortedPosts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="group block">
              <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow">
                <div class="md:flex">
                  {post.data.image && (
                    <div class="md:w-2/5 aspect-video md:aspect-auto overflow-hidden">
                      <img 
                        src={post.data.image} 
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      />
                    </div>
                  )}
                  
                  <div class="p-6 md:p-8 md:flex-1">
                    <div class="flex flex-wrap items-center gap-3 mb-4">
                      <time class="text-sm text-[#64748b]">
                        {post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </time>
                      
                      {post.data.tags.map((tag: string) => (
                        <span class="text-xs text-[#1e3a5f] bg-[#1e3a5f]/10 px-2 py-1 rounded-full">{tag}</span>
                      ))}
                    </div>
                    
                    <h2 class="text-2xl font-bold text-[#1a1a1a] mb-3 group-hover:text-[#1e3a5f] transition-colors">
                      {post.data.title}
                    </h2>
                    
                    <p class="text-[#64748b] mb-4">{post.data.description}</p>
                    
                    <div class="flex items-center text-[#1e3a5f] font-medium">
                      Weiterlesen
                      <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                      </svg>
                    </div>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-lg text-[#64748b]">Noch keine Blog-Beiträge vorhanden.</p>
        </div>
      )}
    </div>
  </div>
</Layout>