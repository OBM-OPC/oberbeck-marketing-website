---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "Marketing Agentur Frankenthal | Oberbeck Marketing";
const description = "Marketing-Agentur in Frankenthal: Webdesign, SEO, Google Ads, Social Media und Markenaufbau für Unternehmen in Frankenthal und der Pfalz. Persönliche Beratung, messbare Ergebnisse.";

const highlights = [
  {
    title: 'Lokal präsent',
    text: 'Direkt in Frankenthal verankert und mit kurzen Wegen für persönliche Abstimmungen.',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z'
  },
  {
    title: 'Regional relevant',
    text: 'Marketing mit Verständnis für die Pfalz, ihre Unternehmen, Zielgruppen und Besonderheiten.',
    icon: 'M3 7h18M3 12h18M3 17h18'
  },
  {
    title: 'Messbare Ergebnisse',
    text: 'Von Sichtbarkeit bis Leadgenerierung: Maßnahmen mit klarer Richtung und nachvollziehbaren KPIs.',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'
  }
];

const services = [
  {
    title: 'Webdesign für Unternehmen in Frankenthal',
    text: 'Moderne Websites, Landingpages und Relaunches für Unternehmen, die in Frankenthal und Umgebung professionell auftreten wollen.',
    points: ['Responsive Websites', 'Conversion-starke Landingpages', 'Texte & Struktur', 'Performance-Optimierung']
  },
  {
    title: 'Lokales SEO',
    text: 'Bessere Auffindbarkeit bei Suchanfragen rund um Frankenthal, die Pfalz und relevante Leistungen in Ihrer Region.',
    points: ['Local SEO', 'Standortseiten', 'Google Unternehmensprofil', 'OnPage-Optimierung']
  },
  {
    title: 'Google Ads',
    text: 'Gezielte Kampagnen für regionale Reichweite, Anfragen und Sichtbarkeit bei relevanten Suchbegriffen.',
    points: ['Suchkampagnen', 'Remarketing', 'Landingpage-Abstimmung', 'Tracking & Reporting']
  },
  {
    title: 'Grafikdesign & Markenauftritt',
    text: 'Damit Kunden sofort verstehen, was Sie anbieten: klarer Markenauftritt, Werbemittel und visuelle Kommunikation.',
    points: ['Logo & Corporate Design', 'Flyer & Broschüren', 'Social Media Assets', 'Anzeigenmotive']
  }
];

const testimonials = [
  {
    quote: "Wir haben jahrelang darauf vertraut, dass Kunden uns einfach finden. Aber die meisten Urlauber buchen heute online — und da waren wir fast unsichtbar. Seit dem Relaunch mit lokalem SEO bekommen wir regelmäßig Anfragen aus der Region und darüber hinaus.",
    author: "Weingut aus der Pfalz",
    location: "Pfalz"
  },
  {
    quote: "Unsere Speisekarte ist top, aber unsere Website sah aus wie aus einer anderen Zeit. Wir wollten etwas, das die Atmosphäre unseres Lokals transportiert — und das funktioniert jetzt. Die Reservierungen über die Website haben spürbar zugenommen.",
    author: "Gastronomie-Betrieb aus der Region",
    location: "Pfalz"
  },
  {
    quote: "Als Handwerksbetrieb war mir Online-Marketing immer suspekt. Aber der regionale Wettbewerb schläft nicht. Mit einer klaren Website und gezieltem Google-Eintrag werden wir jetzt gefunden, wenn jemand in der Pfalz nach unserer Leistung sucht.",
    author: "Dienstleister aus der Region",
    location: "Pfalz"
  }
];

const faqs = [
  {
    question: "Was kostet Marketing für ein kleines Unternehmen in Frankenthal?",
    answer: "Das kommt auf Ihre Ziele und den aktuellen Stand an. Für eine lokale Website mit SEO beginnen Projekte bei einem überschaubaren Budget. Wir besprechen im kostenlosen Erstgespräch, wo der größte Hebel liegt — und was Sinn macht."
  },
  {
    question: "Wie lange dauert es, bis mein Unternehmen in Frankenthal besser gefunden wird?",
    answer: "Eine neue Website ist nach wenigen Wochen live. Bei Google Ads sehen Sie erste Ergebnisse innerhalb von Tagen. Für organisches SEO sollten Sie drei bis sechs Monate einplanen, bis die Sichtbarkeit nachhaltig wächst."
  },
  {
    question: "Brauche ich als Handwerker oder Winzer wirklich eine Website?",
    answer: "Ja — auch wenn viele Kunden Mund-zu-Mund empfehlen, prüfen die meisten vor dem ersten Kontakt online. Wer nicht gefunden wird oder eine veraltete Website hat, verliert oft still und leise an potenzielle Kunden."
  },
  {
    question: "Können Sie auch bestehende Websites optimieren?",
    answer: "Absolut. Viele Unternehmen haben bereits eine Website, die nur technisch oder inhaltlich nicht auf dem neuesten Stand ist. Wir analysieren, was funktioniert — und wo gezielte Verbesserungen den größten Effekt bringen."
  },
  {
    question: "Wie läuft die Zusammenarbeit ab?",
    answer: "Wir starten mit einem unverbindlichen Gespräch vor Ort, per Telefon oder Zoom. Danach erstellen wir ein klares Angebot. Während der Umsetzung halten wir Sie mit regelmäßigen Updates auf dem Laufenden — transparent und ohne Fachjargon."
  }
];
---

<Layout title={title} description={description}>
  <Navigation />

  <div class="min-h-screen bg-gradient-to-b from-[#faf8f5] to-white">
    <section class="pt-32 pb-18 lg:pt-40 lg:pb-24 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-[#52baeb]/5 rounded-full blur-[120px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
          <a href="/" class="hover:text-[#1e3a5f] transition-colors">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-[#1e3a5f] font-medium">Marketing Agentur Frankenthal</span>
        </nav>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Lokale Sichtbarkeit in der Pfalz</span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1a1a1a] mb-6 leading-tight">
              Marketing Agentur in <span class="text-[#1e3a5f]">Frankenthal</span>
            </h1>
            <p class="text-xl text-[#64748b] mb-8">
              Wir unterstützen Unternehmen in <strong>Frankenthal</strong> und der umliegenden Pfalz mit <strong>Webdesign, SEO, Google Ads, Social Media und Markenaufbau</strong> — klar, professionell und messbar.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/#kontakt" class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] text-white font-semibold rounded-xl transition-all hover:scale-105 shadow-xl shadow-[#52baeb]/20">
                Unverbindlich anfragen
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
              <a href="tel:+4915228875801" class="inline-flex items-center justify-center px-8 py-4 bg-white text-[#1e3a5f] font-semibold rounded-xl border-2 border-[#1e3a5f]/10 hover:border-[#1e3a5f]/30 transition-all">
                +49 152 28875801
              </a>
            </div>
          </div>

          <div class="bg-white rounded-3xl p-8 shadow-xl border border-slate-100">
            <h2 class="text-xl font-bold text-[#1a1a1a] mb-6">Warum lokal so wichtig ist</h2>
            <div class="space-y-4">
              {highlights.map((item) => (
                <div class="flex items-start gap-4 p-4 rounded-2xl bg-slate-50 hover:bg-[#52baeb]/5 transition-colors">
                  <div class="w-12 h-12 bg-gradient-to-br from-[#1e3a5f] to-[#52baeb] rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-[#1a1a1a] mb-1">{item.title}</h3>
                    <p class="text-sm text-[#64748b]">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Story Section -->
    <section class="py-18 lg:py-24 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-[#faf8f5] rounded-3xl p-8 lg:p-12 shadow-xl border border-slate-100">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Ihre Geschichte</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#1a1a1a] mb-8">Wenn gute Arbeit allein nicht mehr reicht</h2>
          <div class="space-y-5 text-[#64748b] text-lg leading-relaxed">
            <p>
              Stellen Sie sich vor: Sie haben ein solides Unternehmen in Frankenthal. Ihre Kunden schätzen Ihre Arbeit, Ihr Team ist motiviert, und Ihr Angebot ist besser als das der meisten Mitbewerber. Doch wenn jemand in der Pfalz nach Ihrer Leistung sucht, erscheinen Sie nicht — oder nur weit hinten.
            </p>
            <p>
              Das ist keine Seltenheit. Viele inhabergeführte Betriebe, Weingüter, Gastronomen und Handwerker in Frankenthal haben jahrzehntelang auf Empfehlung und Stammkunden gesetzt. Das funktioniert oft gut — bis es nicht mehr funktioniert. Denn die Art, wie Menschen lokale Anbieter finden, hat sich grundlegend verändert.
            </p>
            <p>
              Heute greifen die meisten Menschen zum Smartphone. Sie suchen "Weingut Frankenthal", "Restaurant Pfalz" oder "Handwerker in der Nähe". Wer dort nicht auftaucht, existiert für diese potenziellen Kunden faktisch nicht. Das ist nicht dramatisch gemeint — aber es ist die Realität, mit der wir täglich arbeiten.
            </p>
            <p>
              Das Gute: Es lässt sich ändern. Mit einer Website, die verständlich kommuniziert, was Sie tun und warum Sie die richtige Wahl sind. Mit einem Google-Eintrag, der gefunden wird. Und mit Inhalten, die zeigen, dass hinter Ihrem Unternehmen echte Menschen stehen — mit Leidenschaft für das, was sie tun.
            </p>
            <p class="text-[#1a1a1a] font-medium">
              Genau dabei unterstützen wir Sie. Nicht mit theoretischem Marketing-Fachchinesisch, sondern mit pragmatischen Maßnahmen, die bei Ihren Kunden ankommen.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-18 lg:py-24 bg-[#faf8f5]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Leistungen in Frankenthal</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#1a1a1a] mb-6">Was wir für Unternehmen vor Ort umsetzen</h2>
          <p class="text-lg text-[#64748b]">
            Viele Unternehmen werden online nicht klar genug verstanden. Genau da setzen wir an: mit einer Positionierung, die Leistungen verständlich macht und Kunden direkt abholt.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
          {services.map((service) => (
            <div class="bg-white rounded-2xl p-8 border border-slate-100 hover:shadow-lg hover:shadow-slate-900/5 transition-all">
              <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{service.title}</h3>
              <p class="text-[#64748b] mb-5 leading-relaxed">{service.text}</p>
              <ul class="space-y-2">
                {service.points.map((point) => (
                  <li class="flex items-start gap-2 text-sm text-[#64748b]">
                    <svg class="w-4 h-4 text-[#52baeb] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-18 lg:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Erfahrungen aus der Region</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#1a1a1a] mb-6">Was Unternehmer aus Frankenthal und der Pfalz sagen</h2>
          <p class="text-lg text-[#64748b]">
            Fiktive, aber realistische Rückmeldungen — so könnten Betriebe aus unserer Region über ihre Zusammenarbeit sprechen.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
          {testimonials.map((t) => (
            <div class="bg-[#faf8f5] rounded-2xl p-8 border border-slate-100 hover:shadow-lg hover:shadow-slate-900/5 transition-all flex flex-col">
              <div class="mb-6">
                <svg class="w-8 h-8 text-[#52baeb]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                </svg>
              </div>
              <blockquote class="text-[#64748b] leading-relaxed mb-6 flex-grow">
                {t.quote}
              </blockquote>
              <div class="pt-6 border-t border-slate-200">
                <p class="font-semibold text-[#1a1a1a]">{t.author}</p>
                <p class="text-sm text-[#64748b]">{t.location}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Lead Magnet Section -->
    <section class="py-18 lg:py-24 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Kostenlos & unverbindlich</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-5">Gratis Local-SEO-Check für Unternehmen in Frankenthal</h2>
            <p class="text-lg text-slate-300 mb-6">
              Finden Sie heraus, wo Ihr Unternehmen online steht — und wo der größte Hebel liegt. Wir prüfen Ihre Sichtbarkeit in Frankenthal und der Pfalz und senden Ihnen eine kurze, verständliche Analyse per E-Mail.
            </p>
            <ul class="space-y-3 text-slate-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#52baeb] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Keine versteckten Kosten
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#52baeb] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Antwort innerhalb von 48 Stunden
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#52baeb] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Kein Verkaufsdruck im Anschluss
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-xl">
            <h3 class="text-2xl font-bold text-[#1a1a1a] mb-2">Ihren Check anfordern</h3>
            <p class="text-[#64748b] mb-6">Wir analysieren Ihre lokale Sichtbarkeit und melden uns bei Ihnen.</p>

            <form
              action="https://formspree.io/f/mqewayyw"
              method="POST"
              class="space-y-5"
            >
              <input type="hidden" name="_subject" value="Local-SEO-Check Anfrage" />

              <div>
                <label for="lm-name" class="block text-sm font-medium text-[#1a1a1a] mb-2">Name *</label>
                <input
                  type="text"
                  id="lm-name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all"
                  placeholder="Max Mustermann"
                />
              </div>

              <div>
                <label for="lm-email" class="block text-sm font-medium text-[#1a1a1a] mb-2">E-Mail *</label>
                <input
                  type="email"
                  id="lm-email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all"
                  placeholder="max@firma.de"
                />
              </div>

              <div>
                <label for="lm-website" class="block text-sm font-medium text-[#1a1a1a] mb-2">Website-URL</label>
                <input
                  type="url"
                  id="lm-website"
                  name="website"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all"
                  placeholder="https://www.ihre-website.de"
                />
              </div>

              <div>
                <label for="lm-problem" class="block text-sm font-medium text-[#1a1a1a] mb-2">Was ist Ihr größtes Problem?</label>
                <select
                  id="lm-problem"
                  name="problem"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all bg-white"
                >
                  <option value="">Bitte wählen...</option>
                  <option value="werde-nicht-gefunden">Werde nicht gefunden</option>
                  <option value="website-veraltet">Website veraltet</option>
                  <option value="keine-zeit">Keine Zeit für Marketing</option>
                  <option value="unsicher">Unsicher wo anfangen</option>
                </select>
              </div>

              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="lm-datenschutz"
                  name="datenschutz"
                  required
                  class="mt-1 w-4 h-4 rounded border-slate-300 text-[#52baeb] focus:ring-[#52baeb]"
                />
                <label for="lm-datenschutz" class="text-sm text-[#64748b]">
                  Ich habe die <a href="/datenschutz" class="text-[#1e3a5f] underline hover:text-[#52baeb]">Datenschutzerklärung</a> gelesen
                  und stimme der Verarbeitung meiner Daten gemäß DSGVO zu. *
                </label>
              </div>

              <button
                type="submit"
                class="w-full py-4 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-all transform hover:scale-[1.02] shadow-xl shadow-[#52baeb]/25"
              >
                Gratis Local-SEO-Check anfordern
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-18 lg:py-24 bg-[#faf8f5]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Häufige Fragen</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#1a1a1a] mb-6">Was Unternehmer in Frankenthal uns oft fragen</h2>
        </div>

        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="bg-white rounded-2xl border border-slate-100 overflow-hidden group" name="faq">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <span class="font-semibold text-[#1a1a1a] text-lg pr-4">{faq.question}</span>
                <span class="flex-shrink-0 w-8 h-8 bg-[#1e3a5f] rounded-full flex items-center justify-center transition-transform group-open:rotate-180">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-[#64748b] leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="py-18 lg:py-24 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-5">Sie möchten in Frankenthal besser gefunden werden?</h2>
        <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
          Dann entwickeln wir gemeinsam einen Auftritt, der Ihre Leistungen verständlich macht und Ihre Sichtbarkeit in Frankenthal und der Pfalz gezielt verbessert.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/#kontakt" class="inline-flex items-center justify-center px-8 py-4 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-all hover:scale-105 shadow-xl shadow-[#52baeb]/25">
            Kostenloses Erstgespräch
          </a>
          <a href="/leistungen" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl transition-all border border-white/20">
            Alle Leistungen ansehen
          </a>
        </div>
      </div>
    </section>

    <script type="application/ld+json">
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'LocalBusiness',
            '@id': 'https://oberbeck-marketing.de/#localbusiness',
            name: 'Oberbeck Marketing',
            description: 'Marketing Agentur in Frankenthal für Webdesign, SEO, Google Ads, Social Media und Markenaufbau.',
            url: 'https://oberbeck-marketing.de',
            telephone: '+49 152 28875801',
            email: 'kontakt@oberbeck-marketing.de',
