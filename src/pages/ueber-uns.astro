---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "Über uns | Oberbeck Marketing - Ihre Agentur in Laumersheim";
const description = "Lernen Sie Philipp Oberbeck kennen. Ihr Marketing-Experte für KMU in Rheinland-Pfalz. Persönlich, erfahren, messbar erfolgreich.";

const values = [
  {
    title: "Messbarkeit",
    description: "Keine Floskeln, nur Zahlen. Wir definieren KPIs und zeigen Ihnen monatlich, was funktioniert.",
    icon: "chart"
  },
  {
    title: "Transparenz", 
    description: "Sie wissen jederzeit, was wir tun und warum. Keine Blackbox, keine überraschenden Rechnungen.",
    icon: "eye"
  },
  {
    title: "Langfristigkeit",
    description: "Wir denken in Partnerschaften, nicht in Projekten. Ihr Erfolg ist unser Erfolg.",
    icon: "heart"
  },
  {
    title: "Regionalität",
    description: "Wir kennen die lokale Wirtschaft in Rheinland-Pfalz. Von Handwerk bis Industrie.",
    icon: "map"
  }
];

const milestones = [
  { year: "2020", title: "Gründung", description: "Start in Laumersheim mit Fokus auf lokale KMU" },
  { year: "2021", title: "Wachstum", description: "Erweiterung auf Social Media und E-Commerce" },
  { year: "2022", title: "Zertifizierungen", description: "Google Ads, Meta und HubSpot zertifiziert" },
  { year: "2023", title: "Expansion", description: "Kunden in Ludwigshafen, Mannheim und Umgebung" },
  { year: "2024", title: "Heute", description: "Full-Service-Agentur mit 13 zufriedenen Kunden" }
];
---

<Layout title={title} description={description}>
  <Navigation />
  
  <div class="min-h-screen bg-gradient-to-b from-[#faf8f5] to-white">
    
    {/* Hero */}
    <section class="pt-32 pb-16 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[#52baeb]/5 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
          <a href="/" class="hover:text-[#1e3a5f] transition-colors">Startseite</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-[#1e3a5f] font-medium">Über uns</span>
        </nav>
        
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Über Oberbeck Marketing</span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1a1a1a] mb-6 leading-tight">
              Marketing, das <span class="text-[#1e3a5f]">funktioniert</span>
            </h1>
            <p class="text-xl text-[#64748b] mb-8">
              Wir sind keine typische Agentur. Keine Buzzwords, keine Ausreden — nur messbare Ergebnisse 
              für Unternehmer in Rheinland-Pfalz.
            </p>
            <blockquote class="text-lg text-[#1e3a5f] italic border-l-4 border-[#52baeb] pl-4">
              "Ich habe Oberbeck Marketing gegründet, weil ich gesehen habe, wie viele KMU 
              Geld für Marketing verbrennen — ohne zu wissen, ob es wirkt."
            </blockquote>
          </div>
          
          <div class="bg-gradient-to-br from-[#1e3a5f] to-[#152d4a] rounded-3xl p-8 text-white">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-20 h-20 bg-gradient-to-br from-[#52baeb] to-[#3a9bd1] rounded-full flex items-center justify-center">
                <span class="text-3xl font-bold">PO</span>
              </div>
              <div>
                <p class="text-2xl font-bold">Philipp Oberbeck</p>
                <p class="text-[#52baeb]">Gründer & Geschäftsführer</p>
              </div>
            </div>
            
            <div class="space-y-3 text-slate-300">
              <p><strong class="text-white">Expertise:</strong> Digital Marketing seit 2018</p>
              <p><strong class="text-white">Fokus:</strong> KMU in Rheinland-Pfalz</p>
              <p><strong class="text-white">Standort:</strong> Laumersheim</p>
              <p><strong class="text-white">Mission:</strong> Messbares Marketing für alle</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Werte */}
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Unsere Werte</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#1a1a1a] mb-6">Was uns unterscheidet</h2>
          <p class="text-lg text-[#64748b]">
            Diese Prinzipien leiten jede Entscheidung, die wir treffen.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {values.map((value) => (
            <div class="bg-[#faf8f5] rounded-2xl p-6 text-center">
              <div class="w-14 h-14 bg-gradient-to-br from-[#1e3a5f] to-[#52baeb] rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[#1a1a1a] mb-2">{value.title}</h3>
              <p class="text-sm text-[#64748b]">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Timeline */}
    <section class="py-20 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16">
          <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Unsere Geschichte</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">Vom Einzelkämpfer zur Agentur</h2>
        </div>

        <div class="space-y-8">
          {milestones.map((milestone, index) => (
            <div class="flex items-start gap-6">
              <div class="w-20 text-right flex-shrink-0">
                <span class="text-2xl font-bold text-[#52baeb]">{milestone.year}</span>
              </div>
              <div class="flex-1 pb-8 border-l-2 border-[#52baeb]/30 pl-6 relative">
                <div class="absolute -left-[9px] top-0 w-4 h-4 bg-[#52baeb] rounded-full"></div>
                <h3 class="text-xl font-bold text-white mb-1">{milestone.title}</h3>
                <p class="text-slate-300">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-20 bg-[#faf8f5]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-[#1a1a1a] mb-4">Lernen Sie uns kennen</h2>
        <p class="text-lg text-[#64748b] mb-8">
          In einem kostenlosen Erstgespräch erfahren Sie, wie wir Ihr Marketing messbar besser machen.
        </p>
        <a href="/#kontakt" class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] text-white font-semibold rounded-xl transition-all hover:scale-105 shadow-xl shadow-[#52baeb]/25">
          Termin vereinbaren
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </section>

    {/* Schema Markup */}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        "name": "Über Oberbeck Marketing",
        "description": "Lernen Sie Philipp Oberbeck kennen - Ihr Marketing-Experte für KMU in Rheinland-Pfalz",
        "url": "https://oberbeck-marketing.de/ueber-uns",
        "mainEntity": {
          "@type": "Organization",
          "@id": "https://oberbeck-marketing.de/#organization",
          "founder": {
            "@type": "Person",
            "name": "Philipp Oberbeck",
            "jobTitle": "Geschäftsführer"
          },
          "foundingDate": "2020",
          "numberOfEmployees": "1",
          "knowsAbout": ["Digital Marketing", "Google Ads", "SEO", "Social Media"]
        }
      }
    </script>
  </div>
  
  <Footer />
</Layout>
