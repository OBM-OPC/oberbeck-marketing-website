---
const author = {
  name: "Philipp Oberbeck",
  jobTitle: "Geschäftsführer & Marketing-Experte",
  company: "Oberbeck Marketing",
  location: "Laumersheim, Rheinland-Pfalz",
  experience: "Seit 2020 helfen wir KMU in der Region, mehr aus ihrem Marketing herauszuholen.",
  expertise: [
    "Digital Marketing Strategie",
    "Google Ads & Performance Marketing", 
    "SEO & Content Marketing",
    "Social Media Marketing",
    "Webdesign & Conversion Optimierung"
  ],
  credentials: [
    "Google Ads zertifiziert",
 "Meta Blueprint zertifiziert",
 "HubSpot Inbound Marketing zertifiziert"
  ],
  philosophy: "Marketing muss messbar sein. Keine Floskeln, keine Ausreden - nur Ergebnisse, die sich in Zahlen beweisen lassen."
};
---

<section id="about" class="py-20 lg:py-32 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a] relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#52baeb]/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-[#52baeb]/5 rounded-full blur-[80px] pointer-events-none"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      <!-- Left: Visual/Avatar -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center justify-center w-32 h-32 bg-gradient-to-br from-[#52baeb] to-[#3a9bd1] rounded-full mb-6 shadow-xl shadow-[#52baeb]/20">
          <span class="text-5xl font-bold text-white">PO</span>
        </div>
        
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-2">
          {author.name}
        </h2>
        <p class="text-[#52baeb] font-medium mb-4">{author.jobTitle}</p>
        
        <div class="flex flex-wrap justify-center lg:justify-start gap-2 mb-6">
          {author.credentials.map((cred) => (
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white/10 rounded-full text-sm text-white/80">
              <svg class="w-4 h-4 text-[#52baeb]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 003.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              {cred}
            </span>
          ))}
        </div>
        
        <blockquote class="text-lg text-slate-300 italic border-l-4 border-[#52baeb] pl-4">
          "{author.philosophy}"
        </blockquote>
      </div>
      
      <!-- Right: Content -->
      <div class="text-white">
        <span class="text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4 block">Über mich</span>
        
        <p class="text-lg text-slate-300 mb-6 leading-relaxed">
          {author.experience}
        </p>
        
        <h3 class="font-semibold text-white mb-3">Meine Expertise:</h3>
        <ul class="space-y-2 mb-8">
          {author.expertise.map((item) => (
            <li class="flex items-center gap-3 text-slate-300">
              <svg class="w-5 h-5 text-[#52baeb] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="#kontakt"
            class="inline-flex items-center justify-center px-6 py-3 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            Kontakt aufnehmen
          </a>
          
          <a 
            href="https://www.instagram.com/oberbeck_marketing"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 border border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Schema Markup for Author -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://oberbeck-marketing.de/#philipp-oberbeck",
    "name": "Philipp Oberbeck",
    "jobTitle": "Geschäftsführer & Marketing-Experte",
    "worksFor": {
      "@id": "https://oberbeck-marketing.de/#organization"
    },
    "description": "Marketing-Experte mit Fokus auf digitale Strategien für KMU in Rheinland-Pfalz. Spezialisiert auf Google Ads, SEO, Social Media und Webdesign.",
    "knowsAbout": [
      "Digital Marketing",
      "Google Ads",
      "SEO",
      "Social Media Marketing",
      "Webdesign",
      "E-Commerce",
      "Marketing Strategie"
    ],
    "alumniOf": {
      "@type": "Organization",
      "name": "Oberbeck Marketing"
    },
    "sameAs": [
      "https://www.instagram.com/oberbeck_marketing"
    ]
  }
</script>
