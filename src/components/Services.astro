---

<section id="leistungen" class="py-20 lg:py-32 bg-[#faf8f5] relative overflow-hidden">
  
  <!-- Background Elements -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-br from-[#52baeb]/5 to-transparent rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-[#1e3a5f]/5 to-transparent rounded-full blur-[100px] pointer-events-none"></div>
  
  <!-- Decorative Shapes -->
  <div class="absolute top-20 left-10 lg:left-20 w-20 h-20 border border-[#52baeb]/10 rounded-2xl rotate-12 hidden lg:block"></div>
  <div class="absolute bottom-40 right-20 w-16 h-16 bg-[#52baeb]/5 rounded-full hidden lg:block"></div>
  <div class="absolute top-1/2 right-10 w-8 h-8 border-2 border-dashed border-[#1e3a5f]/10 rounded-full hidden lg:block"></div>
  
  <!-- Grid Pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(#1e3a5f 1px, transparent 1px); background-size: 40px 40px;"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Leistungen</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-6">
        Alles aus einer Hand
      </h2>
      <p class="text-lg text-[#64748b]">
        Von der Strategie bis zur technischen Umsetzung — wir begleiten Ihr Marketing auf allen Ebenen. 
        Kein outsourcen, keine Abstimmung mit Dritten.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {services.map((service, index) => (
        <div class="service-card bg-white rounded-2xl p-6 lg:p-8 shadow-lg shadow-slate-900/5 border border-slate-100 group relative overflow-hidden">
          <!-- Hover Gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#52baeb]/0 to-[#1e3a5f]/0 group-hover:from-[#52baeb]/5 group-hover:to-[#1e3a5f]/5 transition-all duration-500"></div>
          
          <div class="relative">
            <!-- Icon -->
            <div class="w-14 h-14 bg-gradient-to-br from-[#1e3a5f] to-[#2d4a6f] rounded-xl flex items-center justify-center mb-6 group-hover:bg-gradient-to-br group-hover:from-[#52baeb] group-hover:to-[#3a9bd1] transition-all duration-300">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[service.icon]} />
              </svg>
            </div>

            <!-- Content -->
            <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{service.title}</h3>
            <p class="text-[#64748b] mb-6 leading-relaxed">{service.description}</p>

            <!-- Features -->
            <ul class="space-y-2">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-[#64748b]">
                  <svg class="w-4 h-4 text-[#52baeb] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Links -->
    <div class="mt-16 text-center relative space-y-6">
      <!-- Decorative Line -->
      <div class="absolute left-1/2 -translate-x-1/2 -top-8 w-px h-16 bg-gradient-to-b from-transparent via-[#52baeb]/30 to-transparent"></div>
      
      <a 
        href="/leistungen"
        class="inline-flex items-center justify-center px-6 py-3 text-[#1e3a5f] hover:bg-[#1e3a5f]/5 font-semibold rounded-xl transition-all border-2 border-[#1e3a5f]/20 hover:border-[#1e3a5f]/40"
      >
        Alle Leistungen im Detail
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <div>
        <a 
          href="#kontakt"
          class="inline-flex items-center justify-center px-8 py-4 bg-[#1e3a5f] hover:bg-[#152d4a] text-white font-semibold rounded-xl transition-all transform hover:scale-105 shadow-xl shadow-slate-900/20"
        >
          Unverbindliches Erstgespräch vereinbaren
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
