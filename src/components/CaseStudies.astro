---
const caseStudies = [
  {
    client: "Jürgen Binder Imkereibedarf",
    industry: "E-Commerce / Handel",
    result: "Komplettsystem",
    metric: "Shopify mit Affiliate & Dropshipping",
    description: "Aufbau eines vollautomatisierten E-Commerce-Systems inklusive Affiliate-Marketing-Integration und Dropshipping-Management. Skalierbarer Vertrieb ohne Lagerhaltung.",
    tags: ["E-Commerce", "Shopify", "Affiliate Marketing", "Dropshipping"]
  },
  {
    client: "Martin Fuchs Coaching",
    industry: "Coaching / Personal Development",
    result: "Conversion-Fokus",
    metric: "Optimierte Customer Journey",
    description: "Multisite-Plattform mit Blog für Content-Marketing, Lead-Magnet für Newsletter-Gewinnung und nahtloser Kalender-Integration für direkte Terminbuchungen.",
    tags: ["Webdesign", "Content Strategy", "Lead Generation", "Automation"]
  },
  {
    client: "Fischer Elektro & Pumpentechnik",
    industry: "Handwerk / Industrie",
    result: "360° Branding",
    metric: "Vom Logo bis zur Büroausstattung",
    description: "Komplette Markenentwicklung: Logo-Design, Corporate Identity, Büroausstattung, Fahrzeugbeschriftung und sämtliches Marketing-Material aus einer Hand.",
    tags: ["Branding", "Corporate Design", "Print", "Signage"]
  },
  {
    client: "Pfälzer Kaffeerösterei",
    industry: "Food / Retail",
    result: "Full-Service",
    metric: "Brand bis Checkout-Optimierung",
    description: "Branding, Verpackungsdesign, Onlineshop und strategische Customer Journey Optimierung. Fokus auf Wiederholungskäufe und Customer Lifetime Value.",
    tags: ["Branding", "Packaging", "E-Commerce", "CLV Optimization"]
  },
  {
    client: "SJT Service GmbH",
    industry: "B2B / Family Office",
    result: "Premium Presence",
    metric: "High-Level Webauftritt",
    description: "Exklusive Website für anspruchsvolle Zielgruppe im Family Office Bereich. Understated Luxury Design, das Vertrauen und Diskretion kommuniziert.",
    tags: ["Webdesign", "Branding", "B2B", "Luxury"]
  },
  {
    client: "Aretz24 IT Beratung",
    industry: "IT / Beratung",
    result: "Performance",
    metric: "Ads-optimierte Landingpages",
    description: "Website-Architektur speziell für Paid Advertising ausgelegt. Schnelle Landingpages mit hohen Conversion-Raten für Google Ads Kampagnen.",
    tags: ["Landing Pages", "Google Ads", "Performance", "CRO"]
  }
];
---

<section id="kundenstimmen" class="py-20 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Referenzen</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-6">
        Projekte, die überzeugen
      </h2>
      <p class="text-lg text-[#64748b]">
        Von E-Commerce über Corporate Branding bis hin zu Performance-Marketing — 
        hier sind echte Projekte, die wir für Kunden umgesetzt haben.
      </p>
    </div>

    <!-- Case Studies Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {caseStudies.map((study) => (
        <div class="group bg-[#faf8f5] rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:shadow-slate-900/10 transition-all duration-300 flex flex-col">
          <!-- Result Badge -->
          <div class="mb-6">
            <div class="inline-flex items-center gap-2 bg-[#1e3a5f] text-white px-4 py-2 rounded-xl">
              <span class="text-sm font-bold">{study.result}</span>
            </div>
            <p class="text-sm text-[#64748b] mt-2 font-medium">{study.metric}</p>
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-[#1a1a1a] mb-2">{study.client}</h3>
          <p class="text-sm text-[#52baeb] font-medium mb-4">{study.industry}</p>
          <p class="text-[#64748b] mb-6 leading-relaxed flex-1">{study.description}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {study.tags.map((tag) => (
              <span class="px-3 py-1 bg-white text-xs font-medium text-[#1e3a5f] rounded-full border border-slate-200">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <a 
        href="/#kontakt" 
        class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white font-semibold rounded-xl transition-all transform hover:scale-105 shadow-xl shadow-[#52baeb]/25"
      >
        Ähnliches Projekt besprechen
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
