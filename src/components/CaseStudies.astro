---
const caseStudies = [
  {
    client: "Handwerksbetrieb Müller",
    industry: "Handwerk / Sanitär",
    result: "+127%",
    metric: "mehr Website-Besucher",
    description: "Website-Relaunch mit Fokus auf Local SEO und Conversion-Optimierung. Innerhalb von 3 Monaten signifikante Steigerung der organischen Reichweite.",
    tags: ["Webdesign", "SEO", "Local Marketing"]
  },
  {
    client: "TechStart GmbH",
    industry: "B2B Software",
    result: "-40%",
    metric: "niedrigere Cost-per-Lead",
    description: "Restrukturierung der Google Ads Kampagnen mit Fokus auf Qualität statt Quantität. Höhere Conversion-Rate bei gleichem Budget.",
    tags: ["Google Ads", "Landing Pages", "CRO"]
  },
  {
    client: "Café Sonnenschein",
    industry: "Gastronomie",
    result: "+85%",
    metric: "mehr Social Engagement",
    description: "Aufbau einer authentischen Social-Media-Präsenz mit lokalem Fokus. Steigerung der Sichtbarkeit und direkte Buchungsanfragen über Instagram.",
    tags: ["Social Media", "Content Strategy", "Local Marketing"]
  }
];
---

<section id="kundenstimmen" class="py-20 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Ergebnisse</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-6">
        Zahlen statt Versprechen
      </h2>
      <p class="text-lg text-[#64748b]">
        Hier sind echte Ergebnisse, die ich für KMU in Rheinland-Pfalz erzielt habe. 
        Messbar, nachvollziehbar, real.
      </p>
    </div>

    <!-- Case Studies Grid -->
    <div class="grid lg:grid-cols-3 gap-8">
      {caseStudies.map((study, index) => (
        <div class="group bg-[#faf8f5] rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:shadow-slate-900/10 transition-all duration-300">
          <!-- Result Badge -->
          <div class="mb-6">
            <div class="inline-flex items-baseline gap-1 bg-[#1e3a5f] text-white px-4 py-2 rounded-xl">
              <span class="text-3xl font-bold">{study.result}</span>
            </div>
            <p class="text-sm text-[#64748b] mt-2 font-medium">{study.metric}</p>
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-[#1a1a1a] mb-2">{study.client}</h3>
          <p class="text-sm text-[#52baeb] font-medium mb-4">{study.industry}</p>
          <p class="text-[#64748b] mb-6 leading-relaxed">{study.description}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {study.tags.map((tag) => (
              <span class="px-3 py-1 bg-white text-xs font-medium text-[#1e3a5f] rounded-full border border-slate-200">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Google Reviews Section -->
    <div class="mt-20 bg-gradient-to-br from-[#1e3a5f] to-[#152d4a] rounded-3xl p-8 lg:p-12 text-center">
      <div class="max-w-2xl mx-auto">
        <!-- Stars -->
        <div class="flex justify-center gap-1 mb-6">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-8 h-8 text-[#52baeb]" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>

        <h3 class="text-2xl lg:text-3xl font-bold text-white mb-4">
          Von 9 Kunden mit 5 Sternen bewertet
        </h3>
        <p class="text-slate-300 mb-8">
          Auf Google. Schauen Sie sich die Rezensionen an — echte Meinungen von echten Unternehmern.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="https://g.page/r/CR7qV5d8X5tVEAE/review" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 bg-white text-[#1e3a5f] font-semibold rounded-xl hover:bg-slate-50 transition-colors"
          >
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Google Reviews ansehen
          </a>
          
          <a 
            href="#kontakt"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-white text-white font-semibold rounded-xl hover:bg-white/10 transition-colors"
          >
            Ich will auch 5 Sterne verdienen
          </a>
        </div>
      </div>
    </div>
  </div>
</section>