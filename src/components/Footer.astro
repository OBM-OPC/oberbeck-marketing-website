---
const footerLinks = {
  services: [
    { label: "Alle Leistungen im Detail", href: "/leistungen" },
    { label: "Marketing-Strategie", href: "/leistungen#strategie" },
    { label: "Grafikdesign", href: "/leistungen#design" },
    { label: "Performance Marketing", href: "/leistungen#performance" },
    { label: "Social Media", href: "/leistungen#social-media" },
    { label: "Webdesign", href: "/leistungen#web" },
    { label: "Entwicklung", href: "/leistungen#entwicklung" }
  ],
  company: [
    { label: "Über uns", href: "#warum-oberbeck" },
    { label: "Kundenstimmen", href: "#kundenstimmen" },
    { label: "Blog", href: "/blog" },
    { label: "Kontakt", href: "#kontakt" }
  ],
  legal: [
    { label: "Impressum", href: "/impressum" },
    { label: "Datenschutz", href: "/datenschutz" }
  ]
};

const socialLinks = [
  {
    name: "Instagram",
    href: "https://instagram.com/oberbeck_marketing",
    icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
  }
];
---

<footer class="bg-[#1a1a1a] text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8 mb-12">
      
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="#" class="flex items-center gap-2 mb-6">
          <img 
            src="/images/obm-logo.svg" 
            alt="Oberbeck Marketing Logo" 
            class="h-10 w-auto"
          />
        </a>
        
        <p class="text-slate-400 mb-6 max-w-sm">
          Full-Service-Agentur für KMU in Rheinland-Pfalz. Persönlich, verlässlich, messbar.
        </p>

        <!-- Google Rating -->
        <div class="flex items-center gap-3 mb-6">
          <div class="flex gap-0.5">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-4 h-4 text-[#52baeb]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-sm text-slate-400">4.9 auf Google</span>
        </div>

        <!-- Social Links -->
        <div class="flex gap-4">
          {socialLinks.map((social) => (
            <a 
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-[#52baeb] transition-colors"
              aria-label={social.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold mb-4">Leistungen</h4>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold mb-4">Unternehmen</h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold mb-4">Kontakt</h4>
        <address class="not-italic text-slate-400 text-sm space-y-2">
          <p>Oberbeck Marketing</p>
          <p>Am Mandelberg 15</p>
          <p>67229 Laumersheim</p>
          <p class="pt-2"><a href="tel:+4915228875801" class="hover:text-white transition-colors">+49 152 28875801</a></p>
          <p><a href="mailto:kontakt@oberbeck-marketing.de" class="hover:text-white transition-colors">kontakt@oberbeck-marketing.de</a></p>
        </address>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm">
        © {new Date().getFullYear()} Oberbeck Marketing. Alle Rechte vorbehalten.
      </p>
      
      <div class="flex gap-6">
        {footerLinks.legal.map((link) => (
          <a href={link.href} class="text-slate-500 hover:text-white transition-colors text-sm">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>