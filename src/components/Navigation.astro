---
const navItems = [
  { label: "Leistungen", href: "#leistungen" },
  { label: "Warum Oberbeck", href: "#warum-oberbeck" },
  { label: "Kundenstimmen", href: "#kundenstimmen" },
  { label: "Blog", href: "#blog" },
  { label: "Kontakt", href: "#kontakt" },
];
---

<nav 
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-out"
  data-scrolled="false"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24 transition-all duration-300" id="nav-inner">
      
      {/* Left: Logo + Rating */}
      <div class="flex items-center gap-3">
        <a href="#" class="flex items-center gap-2 group">
          <img 
            src="/images/obm-logo.svg" 
            alt="Oberbeck Marketing Logo" 
            class="h-12 lg:h-14 w-auto transition-all duration-300 group-hover:scale-105"
            id="nav-logo"
          />
        </a>
        
        {/* Google Rating Badge */}
        <div class="hidden md:flex items-center gap-1.5 bg-white/80 backdrop-blur-sm rounded-full px-3 py-1.5 shadow-sm border border-slate-100">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div class="flex items-center gap-1">
            <span class="font-bold text-sm text-slate-800">4.9</span>
            <div class="flex">
              {[1,2,3,4].map(() => (
                <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
              <svg class="w-3 h-3 text-yellow-400" viewBox="0 0 20 20">
                <defs>
                  <linearGradient id="halfStarNav">
                    <stop offset="50%" stop-color="#facc15"/>
                    <stop offset="50%" stop-color="#e2e8f0"/>
                  </linearGradient>
                </defs>
                <path fill="url(#halfStarNav)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      {/* Center: Navigation */}
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a 
            href={item.href} 
            class="nav-link relative px-4 py-2 text-sm font-medium text-slate-600 hover:text-[#1e3a5f] transition-colors rounded-lg hover:bg-slate-50"
            data-section={item.href.replace('#', '')}
          >
            {item.label}
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-[#52baeb] transition-all duration-300 nav-underline"></span>
          </a>
        ))}
      </div>

      {/* Right: CTA */}
      <div class="flex items-center gap-4">
        <a 
          href="#kontakt" 
          class="hidden sm:inline-flex px-5 py-2.5 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white text-sm font-semibold rounded-lg transition-all transform hover:scale-105 shadow-lg shadow-[#52baeb]/25"
        >
          Erstgespräch buchen
        </a>
        
        {/* Mobile Menu Button */}
        <button 
          id="mobile-menu-btn"
          class="lg:hidden relative w-10 h-10 flex items-center justify-center text-slate-600 hover:text-[#1e3a5f] transition-colors rounded-lg hover:bg-slate-50"
          aria-label="Menu öffnen"
          aria-expanded="false"
        >
          <span class="sr-only">Menü öffnen</span>
          <div class="w-6 h-5 relative flex flex-col justify-between">
            <span class="block w-full h-0.5 bg-current transition-all duration-300 origin-center" id="hamburger-top"></span>
            <span class="block w-full h-0.5 bg-current transition-all duration-300" id="hamburger-middle"></span>
            <span class="block w-full h-0.5 bg-current transition-all duration-300 origin-center" id="hamburger-bottom"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  {/* Mobile Menu - Slide in from right */}
  <div 
    id="mobile-menu" 
    class="lg:hidden fixed inset-y-0 right-0 w-[280px] bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-out z-50"
  >
    <div class="flex flex-col h-full">
      {/* Mobile Header */}
      <div class="flex items-center justify-between p-4 border-b border-slate-100">
        <span class="font-semibold text-slate-800">Menü</span>
        <button 
          id="mobile-menu-close"
          class="w-10 h-10 flex items-center justify-center text-slate-500 hover:text-slate-700 rounded-lg hover:bg-slate-50 transition-colors"
          aria-label="Menü schließen"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      
      {/* Mobile Nav Items */}
      <div class="flex-1 overflow-y-auto py-4">
        {navItems.map((item) => (
          <a 
            href={item.href} 
            class="mobile-nav-link block px-6 py-3 text-slate-600 hover:text-[#1e3a5f] hover:bg-slate-50 font-medium transition-colors border-l-4 border-transparent"
            data-section={item.href.replace('#', '')}
          >
            {item.label}
          </a>
        ))}
      </div>
      
      {/* Mobile CTA */}
      <div class="p-4 border-t border-slate-100">
        <a 
          href="#kontakt" 
          class="block w-full px-5 py-3 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white text-center font-semibold rounded-lg transition-colors mobile-nav-link"
        >
          Erstgespräch buchen
        </a>
        
        {/* Mobile Rating */}
        <div class="mt-4 flex items-center justify-center gap-2 text-sm text-slate-500">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span class="font-semibold text-slate-700">4.9</span>
          <span>· 13 Bewertungen</span>
        </div>
      </div>
    </div>
  </div>
  
  {/* Mobile Menu Overlay */}
  <div 
    id="mobile-menu-overlay"
    class="lg:hidden fixed inset-0 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 z-40"
  ></div>
</nav>

<script>
  // Scroll behavior
  const nav = document.getElementById('main-nav');
  const navInner = document.getElementById('nav-inner');
  const navLogo = document.getElementById('nav-logo');
  let lastScroll = 0;
  
  function updateNavOnScroll() {
    const currentScroll = window.scrollY;
    const isScrolled = currentScroll > 50;
    
    // Toggle scrolled state
    nav?.setAttribute('data-scrolled', String(isScrolled));
    
    if (isScrolled) {
      nav?.classList.add('bg-white/95', 'shadow-lg', 'shadow-slate-900/5');
      nav?.classList.remove('bg-transparent');
      navInner?.classList.remove('h-20', 'lg:h-24');
      navInner?.classList.add('h-16', 'lg:h-20');
      if (navLogo) {
        navLogo.classList.remove('h-12', 'lg:h-14');
        navLogo.classList.add('h-10', 'lg:h-12');
      }
    } else {
      nav?.classList.remove('bg-white/95', 'shadow-lg', 'shadow-slate-900/5');
      nav?.classList.add('bg-transparent');
      navInner?.classList.remove('h-16', 'lg:h-20');
      navInner?.classList.add('h-20', 'lg:h-24');
      if (navLogo) {
        navLogo.classList.remove('h-10', 'lg:h-12');
        navLogo.classList.add('h-12', 'lg:h-14');
      }
    }
    
    lastScroll = currentScroll;
  }
  
  window.addEventListener('scroll', updateNavOnScroll, { passive: true });
  updateNavOnScroll();
  
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
  const hamburgerTop = document.getElementById('hamburger-top');
  const hamburgerMiddle = document.getElementById('hamburger-middle');
  const hamburgerBottom = document.getElementById('hamburger-bottom');
  
  function openMobileMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileMenu?.classList.add('translate-x-0');
    mobileMenuOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    mobileMenuOverlay?.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    
    // Animate hamburger to X
    if (hamburgerTop) {
      hamburgerTop.classList.add('rotate-45', 'translate-y-2');
    }
    if (hamburgerMiddle) {
      hamburgerMiddle.classList.add('opacity-0');
    }
    if (hamburgerBottom) {
      hamburgerBottom.classList.add('-rotate-45', '-translate-y-2');
    }
  }
  
  function closeMobileMenu() {
    mobileMenu?.classList.add('translate-x-full');
    mobileMenu?.classList.remove('translate-x-0');
    mobileMenuOverlay?.classList.add('opacity-0', 'pointer-events-none');
    mobileMenuOverlay?.classList.remove('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = '';
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    
    // Reset hamburger
    if (hamburgerTop) {
      hamburgerTop.classList.remove('rotate-45', 'translate-y-2');
    }
    if (hamburgerMiddle) {
      hamburgerMiddle.classList.remove('opacity-0');
    }
    if (hamburgerBottom) {
      hamburgerBottom.classList.remove('-rotate-45', '-translate-y-2');
    }
  }
  
  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('translate-x-0');
    if (isOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });
  
  mobileMenuClose?.addEventListener('click', closeMobileMenu);
  mobileMenuOverlay?.addEventListener('click', closeMobileMenu);
  
  // Close mobile menu on link click
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });
  
  // Active section highlighting
  const sections = navItems.map(item => item.href.replace('#', ''));
  const navLinks = document.querySelectorAll('.nav-link');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link[data-section]');
  
  function updateActiveSection() {
    const scrollPos = window.scrollY + 100;
    
    sections.forEach((sectionId, index) => {
      const section = document.getElementById(sectionId);
      if (section) {
        const top = section.offsetTop;
        const height = section.offsetHeight;
        
        if (scrollPos >= top && scrollPos < top + height) {
          // Desktop nav
          navLinks.forEach(link => {
            const underline = link.querySelector('.nav-underline');
            if (link.getAttribute('data-section') === sectionId) {
              link.classList.add('text-[#1e3a5f]', 'bg-slate-50');
              underline?.classList.remove('w-0');
              underline?.classList.add('w-full');
            } else {
              link.classList.remove('text-[#1e3a5f]', 'bg-slate-50');
              underline?.classList.add('w-0');
              underline?.classList.remove('w-full');
            }
          });
          
          // Mobile nav
          mobileNavLinks.forEach(link => {
            if (link.getAttribute('data-section') === sectionId) {
              link.classList.add('text-[#1e3a5f]', 'border-[#52baeb]', 'bg-slate-50');
              link.classList.remove('border-transparent');
            } else {
              link.classList.remove('text-[#1e3a5f]', 'border-[#52baeb]', 'bg-slate-50');
              link.classList.add('border-transparent');
            }
          });
        }
      }
    });
  }
  
  window.addEventListener('scroll', updateActiveSection, { passive: true });
  updateActiveSection();
</script>