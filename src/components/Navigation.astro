---
const isBlogPage = Astro.url.pathname.startsWith('/blog') || Astro.url.pathname === '/datenschutz' || Astro.url.pathname === '/impressum';

const navItems = [
  { label: "Leistungen", href: "/#leistungen", icon: "briefcase" },
  { label: "Warum Oberbeck", href: "/#warum-oberbeck", icon: "star" },
  { label: "Referenzen", href: "/#kundenstimmen", icon: "users" },
  { label: "Blog", href: "/blog", icon: "newspaper" },
  { label: "Kontakt", href: "/#kontakt", icon: "mail" },
];

const iconPaths: Record<string, string> = {
  briefcase: "M10 2H14C14.55 2 15 2.45 15 3V7C15 7.55 14.55 8 14 8H10C9.45 8 9 7.55 9 7V3C9 2.45 9.45 2 10 2ZM21 7H17V17C17 17.55 16.55 18 16 18H8C7.45 18 7 17.55 7 17V7H3V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V7ZM17 5H21V3C21 1.9 20.1 1 19 1H17V5Z",
  star: "M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z",
  users: "M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z",
  newspaper: "M20 2H4C2.9 2 2 2.9 2 4V20C2 21.1 2.9 22 4 22H20C21.1 22 22 21.1 22 20V4C22 2.9 21.1 2 20 2ZM6 18H12V16H6V18ZM18 14H6V12H18V14ZM18 10H6V8H18V10Z",
  mail: "M20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4ZM20 8L12 13L4 8V6L12 11L20 6V8Z",
};
---

<nav 
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-out"
  data-scrolled="false"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24 transition-all duration-300" id="nav-inner">
      
      <!-- Logo -->
      <a href="/" class="flex items-center group z-50 relative">
        <img 
          src="/images/obm-logo.svg" 
          alt="Oberbeck Marketing" 
          class="h-8 lg:h-10 w-auto transition-all duration-300 group-hover:scale-105"
          id="nav-logo"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a 
            href={item.href} 
            class="nav-link relative px-4 py-2 text-sm font-medium text-slate-600 hover:text-[#1e3a5f] transition-colors rounded-lg hover:bg-slate-50"
            data-section={item.href.replace('/#', '').replace('#', '')}
          >
            {item.label}
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-[#52baeb] transition-all duration-300 nav-underline"></span>
          </a>
        ))}
      </div>

      <!-- Desktop: Theme Toggle + CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Theme Toggle -->
        <button 
          id="theme-toggle"
          class="w-10 h-10 rounded-lg bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 flex items-center justify-center transition-colors"
          aria-label="Dark Mode umschalten"
        >
          <!-- Sun Icon -->
          <svg id="sun-icon" class="w-5 h-5 text-amber-500 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
          </svg>
          <!-- Moon Icon -->
          <svg id="moon-icon" class="w-5 h-5 text-slate-600 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
          </svg>
        </button>
        
        <a 
          href="/#kontakt" 
          class="px-5 py-2.5 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white text-sm font-semibold rounded-lg transition-all transform hover:scale-105 shadow-lg shadow-[#52baeb]/25"
        >
          Erstgespräch buchen
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn"
        class="lg:hidden relative w-12 h-12 flex items-center justify-center rounded-xl transition-all duration-300"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <span class="sr-only">Menü öffnen</span>
        <div class="w-6 h-5 relative flex flex-col justify-between" id="hamburger">
          <span class="block w-full h-0.5 bg-slate-700 transition-all duration-300 ease-out origin-center" id="hamburger-top"></span>
          <span class="block w-full h-0.5 bg-slate-700 transition-all duration-300 ease-out" id="hamburger-middle"></span>
          <span class="block w-full h-0.5 bg-slate-700 transition-all duration-300 ease-out origin-center" id="hamburger-bottom"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu - Full Screen -->
  <div 
    id="mobile-menu" 
    class="lg:hidden fixed inset-0 z-40 bg-white transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]"
  >
    <div class="flex flex-col h-full pt-20 px-6 pb-8">
      
      <!-- Close Button (positioned absolutely) -->
      <button 
        id="mobile-menu-close"
        class="absolute top-6 right-6 w-12 h-12 flex items-center justify-center rounded-full bg-slate-100 hover:bg-slate-200 text-slate-700 transition-colors"
        aria-label="Menü schließen"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      
      <!-- Navigation Links -->
      <div class="flex-1 flex flex-col justify-center">
        <nav class="space-y-2">
          {navItems.map((item, index) => (
            <a 
              href={item.href} 
              class="mobile-nav-link group flex items-center gap-4 p-4 rounded-2xl text-slate-700 hover:text-[#1e3a5f] hover:bg-slate-50 transition-all duration-300"
              data-section={item.href.replace('/#', '').replace('#', '')}
              style={`animation-delay: ${index * 50}ms`}
            >
              <div class="w-12 h-12 rounded-xl bg-slate-100 group-hover:bg-[#52baeb]/10 flex items-center justify-center transition-colors">
                <svg class="w-6 h-6 text-slate-500 group-hover:text-[#52baeb] transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d={iconPaths[item.icon]} />
                </svg>
              </div>
              <span class="text-xl font-semibold">{item.label}</span>
            </a>
          ))}
        </nav>
      </div>
      
      <!-- Bottom Section -->
      <div class="space-y-4 pt-6 border-t border-slate-100">
        <!-- CTA Button -->
        <a 
          href="/#kontakt" 
          class="mobile-nav-link block w-full py-4 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white text-center font-semibold rounded-xl transition-all shadow-lg shadow-[#52baeb]/25"
        >
          Erstgespräch buchen
        </a>
        
        <!-- Contact Info -->
        <div class="flex items-center justify-center gap-6 text-sm text-slate-500">
          <a href="tel:+491712020885" class="flex items-center gap-2 hover:text-[#1e3a5f] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Anrufen
          </a>
          <a href="mailto:kontakt@oberbeck-marketing.de" class="flex items-center gap-2 hover:text-[#1e3a5f] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            E-Mail
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  // Navigation scroll behavior
  const nav = document.getElementById('main-nav');
  const navInner = document.getElementById('nav-inner');
  const navLogo = document.getElementById('nav-logo');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  
  function updateNav() {
    const isScrolled = window.scrollY > 50;
    
    if (isScrolled) {
      nav?.classList.add('bg-white/95', 'shadow-lg', 'shadow-slate-900/5', 'backdrop-blur-sm');
      nav?.classList.remove('bg-transparent');
      navInner?.classList.remove('h-20', 'lg:h-24');
      navInner?.classList.add('h-16', 'lg:h-20');
      navLogo?.classList.remove('h-8', 'lg:h-10');
      navLogo?.classList.add('h-6', 'lg:h-8');
    } else {
      nav?.classList.remove('bg-white/95', 'shadow-lg', 'shadow-slate-900/5', 'backdrop-blur-sm');
      nav?.classList.add('bg-transparent');
      navInner?.classList.remove('h-16', 'lg:h-20');
      navInner?.classList.add('h-20', 'lg:h-24');
      navLogo?.classList.remove('h-6', 'lg:h-8');
      navLogo?.classList.add('h-8', 'lg:h-10');
    }
  }
  
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
  
  // Mobile menu
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const hamburgerTop = document.getElementById('hamburger-top');
  const hamburgerMiddle = document.getElementById('hamburger-middle');
  const hamburgerBottom = document.getElementById('hamburger-bottom');
  
  let isMenuOpen = false;
  
  function openMenu() {
    isMenuOpen = true;
    mobileMenu?.classList.remove('translate-x-full');
    mobileMenu?.classList.add('translate-x-0');
    document.body.style.overflow = 'hidden';
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    mobileMenuBtn?.classList.add('bg-slate-100');
    
    // Animate to X
    hamburgerTop?.classList.add('rotate-45', 'translate-y-[9px]');
    hamburgerMiddle?.classList.add('opacity-0');
    hamburgerBottom?.classList.add('-rotate-45', '-translate-y-[9px]');
  }
  
  function closeMenu() {
    isMenuOpen = false;
    mobileMenu?.classList.add('translate-x-full');
    mobileMenu?.classList.remove('translate-x-0');
    document.body.style.overflow = '';
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    mobileMenuBtn?.classList.remove('bg-slate-100');
    
    // Reset hamburger
    hamburgerTop?.classList.remove('rotate-45', 'translate-y-[9px]');
    hamburgerMiddle?.classList.remove('opacity-0');
    hamburgerBottom?.classList.remove('-rotate-45', '-translate-y-[9px]');
  }
  
  mobileMenuBtn?.addEventListener('click', () => {
    isMenuOpen ? closeMenu() : openMenu();
  });
  
  mobileMenuClose?.addEventListener('click', closeMenu);
  
  // Close on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
  
  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen) closeMenu();
  });
  
  // Theme Toggle
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  
  function updateThemeIcons() {
    const isDark = html.classList.contains('dark');
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');
    
    if (sunIcon && moonIcon) {
      if (isDark) {
        sunIcon.classList.remove('hidden');
        moonIcon.classList.add('hidden');
      } else {
        sunIcon.classList.add('hidden');
        moonIcon.classList.remove('hidden');
      }
    }
  }
  
  themeToggle?.addEventListener('click', () => {
    html.classList.toggle('dark');
    const isDark = html.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateThemeIcons();
  });
  
  // Initialize icons
  updateThemeIcons();
  
  // Active section highlighting (desktop only)
  const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index.html';
  
  if (isHomePage) {
    const sections = ['leistungen', 'warum-oberbeck', 'kundenstimmen', 'kontakt'];
    const navLinks = document.querySelectorAll('.nav-link');
    
    function highlightSection() {
      const scrollPos = window.scrollY + 150;
      
      sections.forEach((sectionId) => {
        const section = document.getElementById(sectionId);
        if (section) {
          const top = section.offsetTop;
          const height = section.offsetHeight;
          
          if (scrollPos >= top && scrollPos < top + height) {
            navLinks.forEach(link => {
              const underline = link.querySelector('.nav-underline');
              if (link.getAttribute('data-section') === sectionId) {
                link.classList.add('text-[#1e3a5f]', 'bg-slate-50');
                underline?.classList.remove('w-0');
                underline?.classList.add('w-full');
              } else {
                link.classList.remove('text-[#1e3a5f]', 'bg-slate-50');
                underline?.classList.add('w-0');
                underline?.classList.remove('w-full');
              }
            });
          }
        }
      });
    }
    
    window.addEventListener('scroll', highlightSection, { passive: true });
    highlightSection();
  }
</script>