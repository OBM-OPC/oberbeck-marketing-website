---
const contactMethods = [
  {
    title: "Telefon",
    value: "+49 (0) 6238 1234567",
    description: "Mo–Fr, 9–17 Uhr",
    icon: "phone"
  },
  {
    title: "E-Mail",
    value: "hello@oberbeck-marketing.de",
    description: "Antwort innerhalb 24h",
    icon: "email"
  },
  {
    title: "Adresse",
    value: "Hauptstraße 123, 67149 Laumersheim",
    description: "Gerne auch bei Ihnen vor Ort",
    icon: "location"
  }
];
---

<section id="kontakt" class="py-20 lg:py-32 bg-[#faf8f5]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
      
      <!-- Left: Info -->
      <div>
        <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Kontakt</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-6">
          Lassen Sie uns reden
        </h2>
        <p class="text-lg text-[#64748b] mb-10">
          Ein unverbindliches Erstgespräch ist kostenlos. Wir schauen uns Ihre aktuelle Situation an 
          und zeigen Ihnen, wo das größte Potenzial liegt.
        </p>

        <!-- Contact Methods -->
        <div class="space-y-6">
          {contactMethods.map((method) => (
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#1e3a5f] rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {method.icon === 'phone' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>}
                  {method.icon === 'email' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>}
                  {method.icon === 'location' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>}
                </svg>
              </div>
              <div>
                <p class="text-sm text-[#64748b] mb-1">{method.title}</p>
                <p class="text-lg font-semibold text-[#1a1a1a]">{method.value}</p>
                <p class="text-sm text-[#64748b]">{method.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Calendly CTA -->
        <div class="mt-10 p-6 bg-[#1e3a5f] rounded-2xl text-white">
          <h3 class="text-xl font-bold mb-2">Lieber direkt einen Termin?</h3>
          <p class="text-slate-300 mb-4">Buchen Sie direkt einen 30-minütigen Zoom-Call.</p>
          <a 
            href="https://calendly.com/oberbeck-marketing/erstgespraech"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Termin buchen
          </a>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="bg-white rounded-2xl p-8 shadow-xl shadow-slate-900/5">
        <h3 class="text-2xl font-bold text-[#1a1a1a] mb-2">Nachricht senden</h3>
        <p class="text-[#64748b] mb-6">Wir antworten innerhalb eines Werktages.</p>

        <form 
          action="https://formspree.io/f/YOUR_FORM_ID" 
          method="POST"
          class="space-y-5"
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-[#1a1a1a] mb-2">Name *</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all"
                placeholder="Max Mustermann"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-[#1a1a1a] mb-2">E-Mail *</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all"
                placeholder="max@firma.de"
              />
            </div>
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-[#1a1a1a] mb-2">Unternehmen</label>
            <input 
              type="text" 
              id="company" 
              name="company"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all"
              placeholder="Musterfirma GmbH"
            />
          </div>

          <div>
            <label for="service" class="block text-sm font-medium text-[#1a1a1a] mb-2">Interessiert an</label>
            <select 
              id="service" 
              name="service"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all bg-white"
            >
              <option value="">Bitte wählen...</option>
              <option value="strategie">Marketing-Strategie</option>
              <option value="design">Webdesign & Branding</option>
              <option value="performance">Google Ads & SEO</option>
              <option value="social">Social Media</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-[#1a1a1a] mb-2">Ihre Nachricht *</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#52baeb] focus:ring-2 focus:ring-[#52baeb]/20 outline-none transition-all resize-none"
              placeholder="Erzählen Sie uns kurz von Ihrem Unternehmen und was Sie erreichen möchten..."
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full py-4 bg-[#52baeb] hover:bg-[#3a9bd1] text-white font-semibold rounded-xl transition-all transform hover:scale-[1.02] shadow-xl shadow-[#52baeb]/25"
          >
            Nachricht senden
          </button>

          <p class="text-xs text-[#64748b] text-center">
            Mit dem Absenden akzeptieren Sie die Datenschutzbestimmungen.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>