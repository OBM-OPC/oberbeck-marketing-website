---
const benefits = [
  {
    title: "Ein Ansprechpartner",
    description: "Kein Ticket-System, kein Account-Manager-Tausch. Sie sprechen immer mit mir — Philipp Oberbeck, Inhaber.",
    icon: "user"
  },
  {
    title: "Vor Ort in Laumersheim",
    description: "Wir können uns persönlich treffen. Kaffee bei Ihnen vor Ort oder im Büro — je nachdem, was Ihnen lieber ist.",
    icon: "location"
  },
  {
    title: "Messbare Ergebnisse",
    description: "Keine Marketing-Buzzwords, sondern harte Zahlen. Wir tracken, was funktioniert, und passen an, was nicht.",
    icon: "chart"
  },
  {
    title: "KMU-Verständnis",
    description: "Ich kenne die Budgets und Zeitdruck kleiner Unternehmen. Keine Überdimensionierung, nur was wirklich hilft.",
    icon: "briefcase"
  },
  {
    title: "Langfristige Partnerschaft",
    description: "Keine Projekte von der Stange. Ich begleite Sie über Monate und Jahre — damit Ihr Marketing nachhaltig wächst.",
    icon: "handshake"
  },
  {
    title: "Transparente Preise",
    description: "Keine versteckten Kosten, keine Überraschungen. Feste Pakete oder Stundensatz — Sie entscheiden, was passt.",
    icon: "shield"
  }
];

const iconPaths: Record<string, string> = {
  user: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
  location: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
  chart: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  briefcase: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M4 6h16M4 6a2 2 0 012-2h12a2 2 0 012 2M4 6v12a2 2 0 002 2h12a2 2 0 002-2V6",
  handshake: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z",
  shield: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
};
---

<section id="warum-oberbeck" class="py-20 lg:py-32 bg-[#1e3a5f] relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-[#152d4a] opacity-30"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#52baeb]/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16">
      <span class="inline-block text-sm font-semibold text-[#52baeb] uppercase tracking-wider mb-4">Warum Oberbeck</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Agenturen gibt es viele.
        <span class="text-[#52baeb]">Warum ich?</span>
      </h2>
      <p class="text-lg text-slate-300">
        Sie haben schon schlechte Erfahrungen mit Agenturen gemacht? Das höre ich oft. 
        Hier ist, was bei Oberbeck Marketing anders läuft.
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {benefits.map((benefit, index) => (
        <div class="group bg-white/5 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#52baeb] rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPaths[benefit.icon]} />
              </svg>
            </div>
            
            <div>
              <h3 class="text-lg font-bold text-white mb-2">{benefit.title}</h3>
              <p class="text-slate-300 text-sm leading-relaxed">{benefit.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Personal Note -->
    <div class="mt-16 bg-white/5 backdrop-blur-sm rounded-2xl p-8 lg:p-12 border border-white/10">
      <div class="grid lg:grid-cols-2 gap-8 items-center">
        <div>
          <blockquote class="text-xl lg:text-2xl text-white font-medium leading-relaxed mb-6">
            „Ich habe Oberbeck Marketing gegründet, weil ich gesemen habe, wie viele KMU 
            von überdimensionierten Agenturen und undurchsichtigen Prozessen frustriert sind. 
            Das kann besser gehen."
          </blockquote>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#52baeb] to-[#3a9bd1] flex items-center justify-center">
              <span class="text-white font-bold">PO</span>
            </div>
            <div>
              <p class="text-white font-semibold">Philipp Oberbeck</p>
              <p class="text-slate-400 text-sm">Inhaber, Oberbeck Marketing</p>
            </div>
          </div>
        </div>
        
        <div class="flex justify-center lg:justify-end">
          <div class="text-center lg:text-right">
            <p class="text-5xl lg:text-6xl font-bold text-[#52baeb] mb-2">5.0</p>
            <div class="flex justify-center lg:justify-end gap-1 mb-2">
              {
                [1, 2, 3, 4, 5].map(() => (
                  <svg class="w-5 h-5 text-[#52baeb]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))
              }
            </div>
            <p class="text-slate-300">Bewertung auf Google</p>
            <p class="text-slate-400 text-sm mt-1">Basierend auf 9 Kundenrezensionen</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
