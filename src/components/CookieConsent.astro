---
const cookieScripts = {
  analytics: [
    { type: 'googleanalytics', id: 'G-EPY5DM3XFF' }
  ],
  marketing: [
    { type: 'metapixel', id: '3348278722020698' }
  ]
};
---

<!-- Minimal Cookie Consent - Bottom Right Corner -->
<div 
  id="cookie-toast" 
  class="fixed bottom-4 right-4 z-40 max-w-xs bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm rounded-2xl shadow-lg border border-slate-200 dark:border-slate-700 p-4 transform translate-y-full opacity-0 transition-all duration-500"
>
  <div class="flex items-start gap-3">
    <span class="text-2xl">🍪</span>
    <div class="flex-1 min-w-0">
      <p class="text-sm text-slate-700 dark:text-slate-300 leading-snug">
        Wir backen Cookies. 
        <a href="/datenschutz" class="underline hover:text-[#1e3a5f] dark:hover:text-[#52baeb]">Mehr</a>
      </p>
      
      <div class="flex items-center gap-2 mt-3">
        <button 
          id="cookie-decline"
          class="text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 transition-colors"
        >
          Nein
        </button>
        
        <button 
          id="cookie-accept"
          class="text-xs bg-[#1e3a5f] hover:bg-[#152d4a] dark:bg-[#52baeb] dark:hover:bg-[#3a9bd1] text-white px-3 py-1.5 rounded-lg transition-colors"
        >
          Okay
        </button>
      </div>
    </div>
    
    <button 
      id="cookie-close"
      class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors -mt-1 -mr-1"
      aria-label="Schließen"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</div>

<!-- Hidden settings panel (accessible via footer) -->
<div 
  id="cookie-settings" 
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50"
>
  <div class="bg-white dark:bg-slate-900 rounded-2xl max-w-md w-full p-6 shadow-2xl">
    <h3 class="font-semibold text-lg mb-4 text-slate-900 dark:text-white">Cookie-Einstellungen</h3>
    
    <div class="space-y-3 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="font-medium text-sm text-slate-700 dark:text-slate-300">Essenziell</p>
          <p class="text-xs text-slate-500">Notwendig für die Funktion</p>
        </div>
        <span class="text-xs bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">Immer an</span>
      </div>
      
      <label class="flex items-center justify-between cursor-pointer">
        <div>
          <p class="font-medium text-sm text-slate-700 dark:text-slate-300">Analyse</p>
          <p class="text-xs text-slate-500">Google Analytics</p>
        </div>
        <input type="checkbox" id="analytics-check" class="w-4 h-4 rounded border-slate-300">
      </label>
      
      <label class="flex items-center justify-between cursor-pointer">
        <div>
          <p class="font-medium text-sm text-slate-700 dark:text-slate-300">Marketing</p>
          <p class="text-xs text-slate-500">Meta Pixel</p>
        </div>
        <input type="checkbox" id="marketing-check" class="w-4 h-4 rounded border-slate-300">
      </label>
    </div>
    
    <div class="flex gap-2">
      <button 
        id="save-settings"
        class="flex-1 bg-[#1e3a5f] hover:bg-[#152d4a] dark:bg-[#52baeb] dark:hover:bg-[#3a9bd1] text-white py-2.5 rounded-lg text-sm font-medium transition-colors"
      >
        Speichern
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    const toast = document.getElementById('cookie-toast');
    const settingsModal = document.getElementById('cookie-settings');
    
    // Check existing consent
    const saved = localStorage.getItem('cookie-consent');
    
    if (!saved) {
      // Show toast after delay
      setTimeout(() => {
        toast?.classList.remove('translate-y-full', 'opacity-0');
      }, 1500);
    } else {
      applyConsent(JSON.parse(saved));
    }
    
    function hideToast() {
      toast?.classList.add('translate-y-full', 'opacity-0');
    }
    
    function saveConsent(prefs) {
      localStorage.setItem('cookie-consent', JSON.stringify(prefs));
      applyConsent(prefs);
      hideToast();
    }
    
    function applyConsent(prefs) {
      if (typeof gtag !== 'undefined') {
        gtag('consent', 'update', {
          'analytics_storage': prefs.analytics ? 'granted' : 'denied',
          'ad_storage': prefs.marketing ? 'granted' : 'denied',
          'ad_user_data': prefs.marketing ? 'granted' : 'denied',
          'ad_personalization': prefs.marketing ? 'granted' : 'denied'
        });
      }
      if (typeof fbq !== 'undefined') {
        fbq('consent', prefs.marketing ? 'grant' : 'revoke');
      }
    }
    
    // Accept all
    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      saveConsent({ essential: true, analytics: true, marketing: true });
    });
    
    // Decline (essential only)
    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      saveConsent({ essential: true, analytics: false, marketing: false });
    });
    
    // Close without choice
    document.getElementById('cookie-close')?.addEventListener('click', () => {
      hideToast();
      // Don't save - will show again on next visit
    });
    
    // Settings panel (can be opened from footer link)
    window.openCookieSettings = function() {
      const current = JSON.parse(localStorage.getItem('cookie-consent') || '{}');
      document.getElementById('analytics-check').checked = current.analytics;
      document.getElementById('marketing-check').checked = current.marketing;
      settingsModal?.classList.remove('hidden');
      settingsModal?.classList.add('flex');
    };
    
    window.closeCookieSettings = function() {
      settingsModal?.classList.add('hidden');
      settingsModal?.classList.remove('flex');
    };
    
    document.getElementById('save-settings')?.addEventListener('click', () => {
      saveConsent({
        essential: true,
        analytics: document.getElementById('analytics-check')?.checked,
        marketing: document.getElementById('marketing-check')?.checked
      });
      window.closeCookieSettings();
    });
    
    // Close on backdrop click
    settingsModal?.addEventListener('click', (e) => {
      if (e.target === settingsModal) window.closeCookieSettings();
    });
  })();
</script>