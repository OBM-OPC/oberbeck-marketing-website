---
const cookieScripts = {
  analytics: [
    { type: 'googleanalytics', id: 'G-EPY5DM3XFF' }
  ],
  marketing: [
    { type: 'metapixel', id: '3348278722020698' }
  ]
};
---

<!-- Cookie Consent Banner -->
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 shadow-lg z-50 hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <div class="flex-1">
        <h3 class="font-semibold text-[#1a1a1a] mb-1">Datenschutzeinstellungen</h3>
        <p class="text-sm text-slate-600">
          Wir verwenden Cookies und ähnliche Technologien, um Ihnen die beste Nutzungserfahrung zu bieten.
          <a href="/datenschutz" class="text-[#1e3a5f] hover:underline">Mehr erfahren</a>
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button
          id="cookie-decline"
          class="px-4 py-2 text-slate-600 hover:text-[#1a1a1a] text-sm font-medium transition-colors"
        >
          Ablehnen
        </button>

        <button
          id="cookie-essential"
          class="px-4 py-2 border-2 border-[#1e3a5f] text-[#1e3a5f] rounded-lg hover:bg-[#1e3a5f] hover:text-white text-sm font-medium transition-colors"
        >
          Nur Essential
        </button>

        <button
          id="cookie-accept"
          class="px-4 py-2 bg-[#52baeb] hover:bg-[#3a9bd1] text-white rounded-lg text-sm font-medium transition-colors"
        >
          Alle Akzeptieren
        </button>
      </div>
    </div>

    <!-- Detailed Settings -->
    <div id="cookie-settings" class="hidden mt-4 pt-4 border-t border-slate-100">
      <div class="grid md:grid-cols-3 gap-4">
        <div class="flex items-start gap-3">
          <input type="checkbox" id="cookie-essential-check" checked disabled class="mt-1 w-4 h-4 rounded border-slate-300">
          <div>
            <label for="cookie-essential-check" class="font-medium text-sm">Essenziell</label>
            <p class="text-xs text-slate-500">Notwendig für die Grundfunktionen der Website.</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <input type="checkbox" id="cookie-analytics-check" class="mt-1 w-4 h-4 rounded border-slate-300 cookie-option">
          <div>
            <label for="cookie-analytics-check" class="font-medium text-sm">Analyse</label>
            <p class="text-xs text-slate-500">Hilft uns, die Website zu verbessern (Google Analytics).</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <input type="checkbox" id="cookie-marketing-check" class="mt-1 w-4 h-4 rounded border-slate-300 cookie-option">
          <div>
            <label for="cookie-marketing-check" class="font-medium text-sm">Marketing</label>
            <p class="text-xs text-slate-500">Für personalisierte Werbung (Meta Pixel).</p>
          </div>
        </div>
      </div>

      <div class="mt-4 flex justify-end">
        <button
          id="cookie-save-settings"
          class="px-4 py-2 bg-[#1e3a5f] hover:bg-[#152d4a] text-white rounded-lg text-sm font-medium transition-colors"
        >
          Einstellungen speichern
        </button>
      </div>
    </div>

    <div class="mt-2 text-center">
      <button
        id="cookie-toggle-settings"
        class="text-xs text-slate-500 hover:text-[#1e3a5f] underline"
      >
        Detaillierte Einstellungen
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    const banner = document.getElementById('cookie-banner');
    const settingsPanel = document.getElementById('cookie-settings');
    const toggleSettings = document.getElementById('cookie-toggle-settings');

    // Check if user has already made a choice
    const cookieConsent = localStorage.getItem('cookie-consent');

    if (!cookieConsent) {
      // Show banner if no choice made
      banner?.classList.remove('hidden');
    } else {
      // Apply saved preferences
      applyCookiePreferences(JSON.parse(cookieConsent));
    }

    // Toggle settings panel
    toggleSettings?.addEventListener('click', function() {
      settingsPanel?.classList.toggle('hidden');
      toggleSettings.textContent = settingsPanel?.classList.contains('hidden')
        ? 'Detaillierte Einstellungen'
        : 'Einstellungen ausblenden';
    });

    // Decline all cookies
    document.getElementById('cookie-decline')?.addEventListener('click', function() {
      saveCookiePreferences({ essential: true, analytics: false, marketing: false });
      banner?.classList.add('hidden');
    });

    // Accept only essential
    document.getElementById('cookie-essential')?.addEventListener('click', function() {
      saveCookiePreferences({ essential: true, analytics: false, marketing: false });
      banner?.classList.add('hidden');
    });

    // Accept all cookies
    document.getElementById('cookie-accept')?.addEventListener('click', function() {
      saveCookiePreferences({ essential: true, analytics: true, marketing: true });
      banner?.classList.add('hidden');
    });

    // Save detailed settings
    document.getElementById('cookie-save-settings')?.addEventListener('click', function() {
      const analytics = document.getElementById('cookie-analytics-check')?.checked || false;
      const marketing = document.getElementById('cookie-marketing-check')?.checked || false;
      saveCookiePreferences({ essential: true, analytics, marketing });
      banner?.classList.add('hidden');
    });

    function saveCookiePreferences(preferences) {
      localStorage.setItem('cookie-consent', JSON.stringify(preferences));
      applyCookiePreferences(preferences);
    }

    function applyCookiePreferences(preferences) {
      // Analytics cookies
      if (preferences.analytics) {
        // Google Analytics is already loaded via consent mode
        if (typeof gtag !== 'undefined') {
          gtag('consent', 'update', {
            'analytics_storage': 'granted'
          });
        }
      } else {
        if (typeof gtag !== 'undefined') {
          gtag('consent', 'update', {
            'analytics_storage': 'denied'
          });
        }
      }

      // Marketing cookies
      if (preferences.marketing) {
        if (typeof gtag !== 'undefined') {
          gtag('consent', 'update', {
            'ad_storage': 'granted',
            'ad_user_data': 'granted',
            'ad_personalization': 'granted'
          });
        }
        // Enable Meta Pixel
        if (typeof fbq !== 'undefined') {
          fbq('consent', 'grant');
        }
      } else {
        if (typeof gtag !== 'undefined') {
          gtag('consent', 'update', {
            'ad_storage': 'denied',
            'ad_user_data': 'denied',
            'ad_personalization': 'denied'
          });
        }
        // Disable Meta Pixel
        if (typeof fbq !== 'undefined') {
          fbq('consent', 'revoke');
        }
      }
    }
  })();
</script>
