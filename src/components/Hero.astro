---
import TrustBadge from './TrustBadge.astro';
---

<section class="relative min-h-screen pt-20 lg:pt-24 overflow-hidden diagonal-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center min-h-[calc(100vh-6rem)] py-12 lg:py-0">
      
      <!-- Left: Image + Trust Badge -->
      <div class="relative order-2 lg:order-1">
        <div class="relative">
          <!-- Background decorative shape -->
          <div class="absolute -top-8 -left-8 w-72 h-72 bg-gradient-to-br from-[#52baeb]/20 to-[#7acdf0]/10 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-[#1e3a5f]/10 rounded-full blur-3xl"></div>
          
          <!-- Photo Container -->
          <div class="relative z-10">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/10">
              <!-- PLACEHOLDER — replace with actual photo of Philipp -->
              <div class="aspect-[4/5] bg-gradient-to-br from-[#1e3a5f] via-[#2d4a6f] to-[#1e3a5f] flex items-center justify-center relative">
                <div class="text-center text-white p-8">
                  <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center border-2 border-white/30">
                    <svg class="w-16 h-16 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  </div>
                  <p class="text-lg font-medium text-white/90">Philipp Oberbeck</p>
                  <p class="text-sm text-white/60 mt-1">Inhaber & Marketingstratege</p>
                </div>
              </div>
              
              <!-- Trust Badge Overlay -->
              <div class="absolute -bottom-4 -right-4 lg:bottom-8 lg:-right-8 z-20">
                <TrustBadge />
              </div>
            </div>
            
            <!-- Decorative element -->
            <div class="absolute -bottom-4 left-8 w-32 h-2 bg-gradient-to-r from-[#52baeb] to-[#7acdf0] rounded-full"></div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="order-1 lg:order-2 lg:pl-8">
        <div class="max-w-xl">
          <!-- Label -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#1e3a5f]/5 rounded-full mb-6 animate-fade-up">
            <span class="w-2 h-2 bg-gradient-to-r from-[#52baeb] to-[#7acdf0] rounded-full animate-pulse"></span>
            <span class="text-sm font-medium text-[#1e3a5f]">Full-Service-Agentur für KMU</span>
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1a1a1a] leading-tight mb-6 animate-fade-up delay-100">
            Marketing, das
            <span class="relative inline-block">
              funktioniert
              <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 12" fill="none">
                <path d="M2 8c40-6 80-6 120 0s76 4 96-4" stroke="#52baeb" stroke-width="4" stroke-linecap="round"/>
              </svg>
            </span>
          </h1>

          <!-- Subheadline -->
          <p class="text-lg sm:text-xl text-[#64748b] mb-8 leading-relaxed animate-fade-up delay-200">
            Strategie, Design und Performance — alles aus einer Hand. 
            Für Unternehmen in Rheinland-Pfalz, die mehr aus ihrem Marketing herausholen wollen.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 animate-fade-up delay-300">
            <a 
              href="#kontakt"
              class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white font-semibold rounded-xl transition-all transform hover:scale-105 shadow-xl shadow-[#52baeb]/25 group"
            >
              Kostenloses Erstgespräch
              <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            
            <a 
              href="#leistungen"
              class="inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-slate-50 text-[#1e3a5f] font-semibold rounded-xl border-2 border-[#1e3a5f]/10 hover:border-[#1e3a5f]/30 transition-all"
            >
              Leistungen entdecken
            </a>
          </div>

          <!-- Trust indicators -->
          <div class="flex flex-wrap items-center gap-6 mt-10 pt-8 border-t border-slate-200 animate-fade-up delay-400">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-slate-600">Messbare Ergebnisse</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-slate-600">Persönliche Beratung</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-slate-600">Vor Ort in Laumersheim</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2">
    <span class="text-xs text-slate-400">Mehr erfahren</span>
    <div class="w-6 h-10 border-2 border-slate-300 rounded-full flex justify-center pt-2">
      <div class="w-1.5 h-3 bg-slate-400 rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
