---
---

<section class="relative min-h-screen pt-20 lg:pt-24 overflow-hidden">
  <!-- Blue light glow effect behind text -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-gradient-to-br from-[#52baeb]/30 via-[#7acdf0]/20 to-transparent rounded-full blur-[100px] pointer-events-none"></div>
  
  <!-- Secondary glow for depth -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[#52baeb]/10 rounded-full blur-[80px] pointer-events-none"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center min-h-[calc(100vh-6rem)] py-12 lg:py-0">
      
      <!-- Content -->
      <div class="max-w-3xl text-center">
          <!-- Label -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#1e3a5f]/5 rounded-full mb-6 animate-fade-up">
            <span class="w-2 h-2 bg-gradient-to-r from-[#52baeb] to-[#7acdf0] rounded-full animate-pulse"></span>
            <span class="text-sm font-medium text-[#1e3a5f]">Full-Service-Agentur für KMU</span>
          </div>

          <!-- Headline -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1a1a1a] leading-tight mb-6 animate-fade-up delay-100">
            Marketing, das
            <span class="relative inline-block">
              funktioniert
              <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 12" fill="none">
                <path d="M2 8c40-6 80-6 120 0s76 4 96-4" stroke="#52baeb" stroke-width="4" stroke-linecap="round"/>
              </svg>
            </span>
          </h1>

          <!-- Subheadline -->
          <p class="text-lg sm:text-xl text-[#64748b] mb-8 leading-relaxed animate-fade-up delay-200">
            Strategie, Design und Performance — alles aus einer Hand. 
            Für Unternehmen in Rheinland-Pfalz, die mehr aus ihrem Marketing herausholen wollen.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up delay-300">
            <a 
              href="#kontakt"
              class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-[#52baeb] to-[#3a9bd1] hover:from-[#3a9bd1] hover:to-[#2d8bc0] text-white font-semibold rounded-xl transition-all transform hover:scale-105 shadow-xl shadow-[#52baeb]/25 group"
            >
              Kostenloses Erstgespräch
              <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            
            <a 
              href="#leistungen"
              class="inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-slate-50 text-[#1e3a5f] font-semibold rounded-xl border-2 border-[#1e3a5f]/10 hover:border-[#1e3a5f]/30 transition-all"
            >
              Leistungen entdecken
            </a>
          </div>

          <!-- Google Reviews Badge -->
          <div class="mt-8 flex items-center justify-center gap-3 animate-fade-up">
            <div class="flex items-center gap-2 bg-white/80 backdrop-blur-sm rounded-full px-4 py-2 shadow-md border border-slate-100">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <div class="flex flex-col">
                <div class="flex items-center gap-1">
                  <span class="font-semibold text-sm text-slate-800">Google Reviews</span>
                  <div class="flex">
                    {/* 4 full stars */}
                    {[1,2,3,4].map(() => (
                      <svg class="w-3.5 h-3.5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    ))}
                    {/* Half star */}
                    <svg class="w-3.5 h-3.5 text-yellow-400" viewBox="0 0 20 20">
                      <defs>
                        <linearGradient id="halfStarHero">
                          <stop offset="50%" stop-color="#facc15"/>
                          <stop offset="50%" stop-color="#e2e8f0"/>
                        </linearGradient>
                      </defs>
                      <path fill="url(#halfStarHero)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  </div>
                </div>
                <span class="text-xs text-slate-500">4.9 · 13 Rezensionen</span>
              </div>
            </div>
          </div>

          <!-- Trust indicators -->
          <div class="flex flex-wrap items-center justify-center gap-6 mt-10 pt-8 border-t border-slate-200 animate-fade-up delay-400">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-slate-600">Messbare Ergebnisse</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-slate-600">Persönliche Beratung</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-slate-600">Vor Ort in Laumersheim</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#leistungen" class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 group cursor-pointer">
    <span class="text-xs text-slate-400 group-hover:text-[#1e3a5f] transition-colors">Mehr erfahren</span>
    <div class="w-6 h-10 border-2 border-slate-300 group-hover:border-[#1e3a5f] rounded-full flex justify-center pt-2 transition-colors">
      <div class="w-1.5 h-3 bg-slate-400 group-hover:bg-[#1e3a5f] rounded-full animate-bounce transition-colors"></div>
    </div>
  </a>
</section>
