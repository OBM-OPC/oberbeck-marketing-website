---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = sortedPosts.find((post: any) => post.data.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter((post: any) => post.id !== featuredPost?.id).slice(0, 3);
---

<section id="blog" class="py-20 lg:py-32 bg-white">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <span class="inline-block text-sm font-semibold text-[#f59e0b] uppercase tracking-wider mb-4">Blog</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-4">
          Marketing-Wissen für KMU
        </h2>
        <p class="text-lg text-[#64748b] max-w-2xl">
          Praktische Tipps, aktuelle Trends und erprobte Strategien — speziell für kleine und mittelständische Unternehmen.
        </p>
      </div>
      
      <a 
        href="/blog" 
        class="inline-flex items-center text-[#1e3a5f] font-semibold hover:text-[#f59e0b] transition-colors group"
      >
        Alle Artikel ansehen
        <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    {sortedPosts.length > 0 ? (
      <div class="grid lg:grid-cols-2 gap-8">
        
        <!-- Featured Post -->
        {featuredPost && (
          <a href={`/blog/${featuredPost.id}`} class="group block">
            <article class="bg-[#faf8f5] rounded-2xl overflow-hidden h-full hover:shadow-xl transition-shadow">
              {featuredPost.data.image && (
                <div class="aspect-video overflow-hidden">
                  <img 
                    src={featuredPost.data.image} 
                    alt={featuredPost.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}
              
              <div class="p-6 lg:p-8">
                <div class="flex items-center gap-4 mb-4">
                  <span class="px-3 py-1 bg-[#f59e0b] text-white text-xs font-semibold rounded-full">
                    Empfohlen
                  </span>
                  <time class="text-sm text-[#64748b]">
                    {featuredPost.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                </div>
                
                <h3 class="text-xl lg:text-2xl font-bold text-[#1a1a1a] mb-3 group-hover:text-[#1e3a5f] transition-colors">
                  {featuredPost.data.title}
                </h3>
                
                <p class="text-[#64748b] mb-4 line-clamp-3">{featuredPost.data.description}</p>
                
                <div class="flex items-center gap-2 text-sm text-[#1e3a5f] font-medium">
                  Weiterlesen
                  <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </div>
              </div>
            </article>
          </a>
        )}

        <!-- Recent Posts List -->
        <div class="space-y-6">
          {recentPosts.map((post: any) => (
            <a href={`/blog/${post.id}`} class="group block">
              <article class="flex gap-4 p-4 rounded-xl hover:bg-[#faf8f5] transition-colors">
                {post.data.image && (
                  <div class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden">
                    <img 
                      src={post.data.image} 
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                    />
                  </div>
                )}
                
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-2">
                    <time class="text-xs text-[#64748b]">
                      {post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'short' })}
                    </time>
                    
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="text-xs text-[#1e3a5f] bg-[#1e3a5f]/10 px-2 py-0.5 rounded-full">{tag}</span>
                    ))}
                  </div>
                  
                  <h3 class="font-bold text-[#1a1a1a] mb-1 group-hover:text-[#1e3a5f] transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  
                  <p class="text-sm text-[#64748b] line-clamp-2">{post.data.description}</p>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <!-- Empty State -->
      <div class="text-center py-16 bg-[#faf8f5] rounded-2xl">
        <div class="w-16 h-16 mx-auto mb-4 bg-[#1e3a5f]/10 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-[#1e3a5f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-[#1a1a1a] mb-2">Blog-Beiträge folgen bald</h3>
        <p class="text-[#64748b]">Wir arbeiten an hochwertigem Content für Sie.</p>
      </div>
    )}
  </div>
</section>